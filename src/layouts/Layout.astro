---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Chronicles of the Motley Marauders — a D&D campaign journal" } = Astro.props;
const currentPath = Astro.url.pathname;
const ogImage = `${Astro.url.origin}/great-protector.jpg`;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/characters', label: 'The Party' },
  { href: '/story', label: 'Story Updates' },
  { href: '/journey', label: 'The Journey' },
  { href: '/quotes', label: 'Quotes' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | The Motley Marauders</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Open Graph / social share -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | The Motley Marauders`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | The Motley Marauders`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen flex flex-col">

    <!-- Header / Nav -->
    <header class="sticky top-0 z-50 border-b border-stone-800/80" style="background: rgba(13,10,7,0.95); backdrop-filter: blur(8px);">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between gap-6">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group no-underline">
          <div>
            <div class="font-cinzel-decorative text-gold text-sm font-bold leading-tight text-glow-gold" style="font-family: 'Cinzel Decorative', serif; color: #f0c040;">
              The Motley
            </div>
            <div class="font-cinzel-decorative text-gold-light text-base font-bold leading-tight" style="font-family: 'Cinzel Decorative', serif; color: #f0c040;">
              Marauders
            </div>
          </div>
        </a>

        <!-- Nav -->
        <nav class="hidden md:flex items-center gap-6">
          {navLinks.map(link => (
            <a
              href={link.href}
              class={`nav-link ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'active' : ''}`}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- Mobile menu toggle -->
        <button id="mobile-menu-btn" class="md:hidden" aria-label="Menu" aria-expanded="false" style="color:#c9a96e; background:none; border:none; cursor:pointer; z-index:200; position:relative;">
          <!-- Hamburger icon -->
          <svg id="menu-icon-open" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <!-- Close icon -->
          <svg id="menu-icon-close" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:none;" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </header>

    <!-- Fullscreen mobile nav overlay -->
    <div id="mobile-nav" style="
      display: none;
      position: fixed;
      inset: 0;
      z-index: 150;
      background: rgba(10,7,4,0.97);
      backdrop-filter: blur(12px);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0;
    ">
      <!-- Decorative top/bottom borders -->
      <div style="position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(to right, transparent, #c9a227, transparent);"></div>
      <div style="position:absolute; bottom:0; left:0; right:0; height:3px; background:linear-gradient(to right, transparent, #c9a227, transparent);"></div>

      <!-- Close button -->
      <button id="mobile-nav-close" aria-label="Close menu" style="position:absolute; top:1.25rem; right:1.25rem; background:none; border:none; cursor:pointer; color:#c9a96e; padding:0.5rem; line-height:0;">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <div style="font-family:'Cinzel Decorative',serif; color:#c9a227; font-size:0.65rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:3rem;">Navigate</div>

      <nav style="display:flex; flex-direction:column; align-items:center; gap:2rem;">
        {navLinks.map(link => (
          <a
            href={link.href}
            style={`font-family:'Cinzel',serif; font-size:1.6rem; font-weight:700; letter-spacing:0.08em; text-decoration:none; transition:color 0.2s, text-shadow 0.2s; ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'color:#f0c040; text-shadow:0 0 20px rgba(201,162,39,0.4);' : 'color:#c9a96e;'}`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div style="position:absolute; bottom:2.5rem; font-family:'Cinzel',serif; font-size:0.65rem; letter-spacing:0.2em; color:#6b5a3e; text-transform:uppercase;">The Motley Marauders</div>
    </div>

    <!-- Main -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-stone-800/60 mt-20 py-10" style="border-color: rgba(61,46,24,0.6);">
      <div class="max-w-6xl mx-auto px-4 text-center">
        <div class="rune-divider mb-6">
          <span style="color: #c9a227; font-family: 'Cinzel Decorative', serif; font-size: 0.8rem;">✦ ✦ ✦</span>
        </div>
        <p class="font-cinzel text-xs tracking-widest uppercase" style="color: #6b5a3e; font-family: 'Cinzel', serif;">
          Chronicles of the Motley Marauders &bull; May the dice ever roll in your favour
        </p>
      </div>
    </footer>

    <!-- Back to top -->
    <button id="back-to-top" aria-label="Back to top" style="
      position: fixed;
      bottom: 4rem;
      right: 2rem;
      z-index: 99;
      width: 3rem;
      height: 3rem;
      border-radius: 50%;
      background: rgba(26,18,8,0.92);
      border: 1px solid #c9a227;
      color: #c9a227;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      opacity: 0;
      pointer-events: none;
      transform: translateY(8px);
      transition: opacity 0.3s ease, transform 0.3s ease, border-color 0.2s, color 0.2s, box-shadow 0.2s;
      backdrop-filter: blur(6px);
    ">
      <!-- Ornate broadhead arrowhead pointing up -->
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <!-- Outer broadhead with swept barbs -->
        <path d="M12 2 L19 13 L15 11.5 L14.5 17.5 L12 16 L9.5 17.5 L9 11.5 L5 13 Z"/>
        <!-- Decorative centre ridge -->
        <path d="M12 5.5 L12 15.5" stroke="rgba(13,10,7,0.45)" stroke-width="1" fill="none" stroke-linecap="round"/>
        <!-- Small ornate tang notch at base -->
        <path d="M10.5 16.8 L12 19 L13.5 16.8" fill="currentColor"/>
      </svg>
    </button>

    <script is:inline>
      // Mobile menu toggle
      (function () {
        const btn      = document.getElementById('mobile-menu-btn');
        const nav      = document.getElementById('mobile-nav');
        const iconOpen = document.getElementById('menu-icon-open');
        const iconClose= document.getElementById('menu-icon-close');
        if (!btn || !nav) return;

        function openMenu() {
          nav.style.display = 'flex';
          btn.setAttribute('aria-expanded', 'true');
          iconOpen.style.display  = 'none';
          iconClose.style.display = 'block';
          document.body.style.overflow = 'hidden';
        }
        function closeMenu() {
          nav.style.display = 'none';
          btn.setAttribute('aria-expanded', 'false');
          iconOpen.style.display  = 'block';
          iconClose.style.display = 'none';
          document.body.style.overflow = '';
        }

        btn.addEventListener('click', () => {
          btn.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
        });

        // Close when a nav link is clicked
        nav.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

        // Close button inside overlay
        const closeBtn = document.getElementById('mobile-nav-close');
        if (closeBtn) closeBtn.addEventListener('click', closeMenu);
      })();

      (function () {
        const els = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale, .reveal-blur, .reveal-rotate');
        if (!els.length) return;
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.1 });
        els.forEach(el => io.observe(el));
      })();

      // Back to top
      (function () {
        const btn = document.getElementById('back-to-top');
        if (!btn) return;

        window.addEventListener('scroll', () => {
          const show = window.scrollY > 400;
          btn.style.opacity      = show ? '1'    : '0';
          btn.style.pointerEvents = show ? 'auto' : 'none';
          btn.style.transform    = show ? 'translateY(0)' : 'translateY(8px)';
        }, { passive: true });

        btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        btn.addEventListener('mouseenter', () => {
          btn.style.color       = '#f0c040';
          btn.style.borderColor = '#f0c040';
          btn.style.transform   = 'translateY(-3px)';
          btn.style.boxShadow   = '0 0 18px rgba(201,162,39,0.35), 0 4px 14px rgba(0,0,0,0.4)';
        });
        btn.addEventListener('mouseleave', () => {
          btn.style.color       = '#c9a227';
          btn.style.borderColor = '#c9a227';
          btn.style.transform   = 'translateY(0)';
          btn.style.boxShadow   = 'none';
        });
      })();

      // Zoomable map
      (function () {
        document.querySelectorAll('.map-zoom-wrap').forEach(wrap => {
          const img = wrap.querySelector('.map-zoom-img');
          const MIN = 1, MAX = 4, STEP = 0.4;
          let scale = 1, ox = 0, oy = 0;

          function clamp(val, lo, hi) { return Math.max(lo, Math.min(hi, val)); }

          function apply(animated) {
            img.style.transition = animated ? 'transform 0.18s ease' : 'none';
            img.style.transform  = `translate(${ox}px,${oy}px) scale(${scale})`;
          }

          function clampPan() {
            const iw = wrap.offsetWidth  * scale;
            const ih = wrap.offsetHeight * scale;
            const ww = wrap.offsetWidth;
            const wh = wrap.offsetHeight;
            ox = clamp(ox, Math.min(0, ww - iw), 0);
            oy = clamp(oy, Math.min(0, wh - ih), 0);
          }

          function zoomTo(newScale, cx, cy) {
            // cx/cy = focal point in wrap coords
            const ratio = newScale / scale;
            ox = cx - ratio * (cx - ox);
            oy = cy - ratio * (cy - oy);
            scale = newScale;
            clampPan();
            apply(true);
          }

          function reset() { scale = 1; ox = 0; oy = 0; apply(true); }

          // Buttons (controls are siblings, not inside wrap)
          wrap.parentElement.querySelectorAll('.map-zoom-btn').forEach(btn => {
            btn.addEventListener('click', e => {
              e.stopPropagation();
              const action = btn.dataset.zoom;
              const cx = wrap.offsetWidth  / 2;
              const cy = wrap.offsetHeight / 2;
              if (action === 'in')    zoomTo(clamp(scale + STEP, MIN, MAX), cx, cy);
              if (action === 'out')   zoomTo(clamp(scale - STEP, MIN, MAX), cx, cy);
              if (action === 'reset') reset();
            });
          });

          // Mouse wheel
          wrap.addEventListener('wheel', e => {
            e.preventDefault();
            const rect = wrap.getBoundingClientRect();
            const cx   = e.clientX - rect.left;
            const cy   = e.clientY - rect.top;
            const delta = e.deltaY < 0 ? STEP : -STEP;
            zoomTo(clamp(scale + delta, MIN, MAX), cx, cy);
          }, { passive: false });

          // Mouse drag
          let drag = false, startX, startY, startOx, startOy;
          wrap.addEventListener('mousedown', e => {
            if (scale <= 1) return;
            drag = true; wrap.classList.add('dragging');
            startX = e.clientX; startY = e.clientY;
            startOx = ox; startOy = oy;
          });
          window.addEventListener('mousemove', e => {
            if (!drag) return;
            ox = startOx + (e.clientX - startX);
            oy = startOy + (e.clientY - startY);
            clampPan(); apply(false);
          });
          window.addEventListener('mouseup', () => {
            drag = false; wrap.classList.remove('dragging');
          });

          // Touch pinch + drag
          let lastDist = null, lastTx, lastTy, lastTOx, lastTOy;
          wrap.addEventListener('touchstart', e => {
            if (e.touches.length === 2) {
              lastDist = Math.hypot(
                e.touches[0].clientX - e.touches[1].clientX,
                e.touches[0].clientY - e.touches[1].clientY
              );
            } else if (e.touches.length === 1 && scale > 1) {
              lastTx = e.touches[0].clientX; lastTy = e.touches[0].clientY;
              lastTOx = ox; lastTOy = oy;
            }
          }, { passive: true });
          wrap.addEventListener('touchmove', e => {
            if (e.touches.length === 2) {
              e.preventDefault();
              const dist = Math.hypot(
                e.touches[0].clientX - e.touches[1].clientX,
                e.touches[0].clientY - e.touches[1].clientY
              );
              const rect = wrap.getBoundingClientRect();
              const cx = ((e.touches[0].clientX + e.touches[1].clientX) / 2) - rect.left;
              const cy = ((e.touches[0].clientY + e.touches[1].clientY) / 2) - rect.top;
              zoomTo(clamp(scale * (dist / lastDist), MIN, MAX), cx, cy);
              lastDist = dist;
            } else if (e.touches.length === 1 && scale > 1) {
              e.preventDefault();
              ox = lastTOx + (e.touches[0].clientX - lastTx);
              oy = lastTOy + (e.touches[0].clientY - lastTy);
              clampPan(); apply(false);
            }
          }, { passive: false });
          wrap.addEventListener('touchend', () => { lastDist = null; });
        });
      })();
    </script>
  </body>
</html>
