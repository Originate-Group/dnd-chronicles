---
import Layout from '../layouts/Layout.astro';
import { journeyMilestones, storyUpdates } from '../data/story';

---

<Layout title="The Journey" description="A timeline of the Motley Marauders' journey across the realm.">

    <!-- Page header -->
    <div style="padding:5rem 1rem 3rem; text-align:center; border-bottom:1px solid #3d2e18; position:relative; overflow:hidden;">

      <!-- Serpent — left side -->
      <div class="header-deco-img deco-mobile-show" style="position:absolute; left:0; bottom:0; top:0; width:clamp(180px,28vw,360px); pointer-events:none; z-index:0;">
        <img
          src="/serpent.jpg"
          alt=""
          style="width:100%; height:100%; object-fit:cover; object-position:right top; opacity:0.75; mask-image:linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%); -webkit-mask-image:linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);"
        />
      </div>

      <!-- Dwarfs — right side -->
      <div class="header-deco-img" style="position:absolute; right:0; bottom:0; top:0; width:clamp(180px,28vw,360px); pointer-events:none; z-index:0;">
        <img
          src="/dwarfs.jpg"
          alt=""
          style="width:100%; height:100%; object-fit:cover; object-position:center top; opacity:0.75; mask-image:linear-gradient(to left, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%); -webkit-mask-image:linear-gradient(to left, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);"
        />
      </div>

      <!-- Constellation map -->
      <svg class="constell-svg" viewBox="0 0 1200 300" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

        <!-- Group A: top-left — 5 stars -->
        <g class="constell" style="--delay:0s; --dur:11s;">
          <line x1="70"  y1="35"  x2="140" y2="18"  class="cline"/>
          <line x1="140" y1="18"  x2="195" y2="52"  class="cline"/>
          <line x1="195" y1="52"  x2="158" y2="92"  class="cline"/>
          <line x1="158" y1="92"  x2="72"  y2="78"  class="cline"/>
          <circle cx="70"  cy="35"  r="1.4" class="cstar pa"/>
          <circle cx="140" cy="18"  r="1.8" class="cstar pb"/>
          <circle cx="195" cy="52"  r="1.1" class="cstar pc"/>
          <circle cx="158" cy="92"  r="1.4" class="cstar pa"/>
          <circle cx="72"  cy="78"  r="0.9" class="cstar pb"/>
        </g>

        <!-- Group B: top-right — 4 stars -->
        <g class="constell" style="--delay:0.8s; --dur:9s;">
          <line x1="978"  y1="22"  x2="1048" y2="12"  class="cline"/>
          <line x1="1048" y1="12"  x2="1112" y2="30"  class="cline"/>
          <line x1="1112" y1="30"  x2="1092" y2="74"  class="cline"/>
          <circle cx="978"  cy="22"  r="1.1" class="cstar pb"/>
          <circle cx="1048" cy="12"  r="1.6" class="cstar pa"/>
          <circle cx="1112" cy="30"  r="1.2" class="cstar pc"/>
          <circle cx="1092" cy="74"  r="1.0" class="cstar pb"/>
        </g>

        <!-- Group C: bottom-left — triangle -->
        <g class="constell" style="--delay:0.4s; --dur:13s;">
          <line x1="82"  y1="222" x2="162" y2="248" class="cline"/>
          <line x1="162" y1="248" x2="102" y2="284" class="cline"/>
          <line x1="102" y1="284" x2="82"  y2="222" class="cline"/>
          <circle cx="82"  cy="222" r="1.5" class="cstar pa"/>
          <circle cx="162" cy="248" r="1.2" class="cstar pc"/>
          <circle cx="102" cy="284" r="1.0" class="cstar pb"/>
        </g>

        <!-- Group D: bottom-right — 5 stars -->
        <g class="constell" style="--delay:1.4s; --dur:10s;">
          <line x1="1055" y1="215" x2="1128" y2="232" class="cline"/>
          <line x1="1128" y1="232" x2="1152" y2="272" class="cline"/>
          <line x1="1152" y1="272" x2="1082" y2="282" class="cline"/>
          <line x1="1082" y1="282" x2="1042" y2="255" class="cline"/>
          <circle cx="1055" cy="215" r="1.2" class="cstar pc"/>
          <circle cx="1128" cy="232" r="1.6" class="cstar pa"/>
          <circle cx="1152" cy="272" r="1.0" class="cstar pb"/>
          <circle cx="1082" cy="282" r="1.4" class="cstar pa"/>
          <circle cx="1042" cy="255" r="0.9" class="cstar pc"/>
        </g>

        <!-- Group E: left edge — 4 stars -->
        <g class="constell" style="--delay:1.8s; --dur:14s;">
          <line x1="28"  y1="118" x2="60"  y2="138" class="cline"/>
          <line x1="60"  y1="138" x2="46"  y2="170" class="cline"/>
          <line x1="46"  y1="170" x2="16"  y2="158" class="cline"/>
          <circle cx="28"  cy="118" r="1.2" class="cstar pb"/>
          <circle cx="60"  cy="138" r="1.5" class="cstar pa"/>
          <circle cx="46"  cy="170" r="1.0" class="cstar pc"/>
          <circle cx="16"  cy="158" r="1.1" class="cstar pb"/>
        </g>

        <!-- Group F: right edge — 3 stars -->
        <g class="constell" style="--delay:1.1s; --dur:8s;">
          <line x1="1158" y1="110" x2="1132" y2="150" class="cline"/>
          <line x1="1132" y1="150" x2="1162" y2="178" class="cline"/>
          <circle cx="1158" cy="110" r="1.4" class="cstar pa"/>
          <circle cx="1132" cy="150" r="1.0" class="cstar pc"/>
          <circle cx="1162" cy="178" r="1.2" class="cstar pb"/>
        </g>

        <!-- Group G: upper-centre-left — 3 stars -->
        <g class="constell" style="--delay:0.5s; --dur:15s;">
          <line x1="292" y1="24"  x2="348" y2="10"  class="cline"/>
          <line x1="348" y1="10"  x2="388" y2="42"  class="cline"/>
          <circle cx="292" cy="24"  r="1.0" class="cstar pc"/>
          <circle cx="348" cy="10"  r="1.6" class="cstar pa"/>
          <circle cx="388" cy="42"  r="1.1" class="cstar pb"/>
        </g>

        <!-- Group H: upper-centre-right — 4 stars -->
        <g class="constell" style="--delay:1.2s; --dur:12s;">
          <line x1="828" y1="16"  x2="880" y2="8"   class="cline"/>
          <line x1="880" y1="8"   x2="930" y2="24"  class="cline"/>
          <line x1="930" y1="24"  x2="918" y2="60"  class="cline"/>
          <circle cx="828" cy="16"  r="1.1" class="cstar pb"/>
          <circle cx="880" cy="8"   r="1.8" class="cstar pa"/>
          <circle cx="930" cy="24"  r="1.0" class="cstar pc"/>
          <circle cx="918" cy="60"  r="1.2" class="cstar pb"/>
        </g>

        <!-- Lone guide stars — scattered, independent pulse -->
        <circle cx="240"  cy="148" r="0.9" class="cstar lone" style="--ld:0.5s;"/>
        <circle cx="375"  cy="268" r="1.1" class="cstar lone" style="--ld:1.2s;"/>
        <circle cx="598"  cy="22"  r="1.2" class="cstar lone" style="--ld:0.2s;"/>
        <circle cx="822"  cy="262" r="0.8" class="cstar lone" style="--ld:1.7s;"/>
        <circle cx="452"  cy="278" r="1.0" class="cstar lone" style="--ld:0.9s;"/>
        <circle cx="748"  cy="20"  r="0.9" class="cstar lone" style="--ld:1.4s;"/>
        <circle cx="168"  cy="180" r="0.8" class="cstar lone" style="--ld:1.0s;"/>
        <circle cx="1035" cy="145" r="1.0" class="cstar lone" style="--ld:2.0s;"/>

      </svg>

      <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.75rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:1rem; position:relative; z-index:1;">From There to Here</p>
      <h1 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:clamp(2rem,5vw,3.5rem); font-weight:700; position:relative; z-index:1;" class="text-glow-gold">
        The Journey So Far
      </h1>
      <div class="rune-divider" style="max-width:16rem; margin:1.5rem auto 0; position:relative; z-index:1;"></div>
      <p style="color:#c9a96e; font-style:italic; margin-top:1rem; max-width:40rem; margin-left:auto; margin-right:auto; position:relative; z-index:1;">
        Every road walked, every enemy made, every impossible situation narrowly survived — laid out in order of foolishness.
      </p>
    </div>

    <!-- Stats bar -->
    <div class="reveal" style="border-bottom:1px solid #3d2e18; padding:1.5rem 1rem;">
      <div class="stats-grid" style="max-width:72rem; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit, minmax(120px,1fr)); gap:1rem; text-align:center;">
        {[
          { label: 'Sessions Played',   value: storyUpdates.length },
          { label: 'Locations Visited', value: journeyMilestones.length },
          { label: 'Enemies Made',      value: '3+' },
          { label: 'Times Almost Died', value: '∞' },
          { label: 'Current Level',     value: 7 },
        ].map(stat => (
          <div>
            <div style="font-family:'Cinzel',serif; color:#f0c040; font-size:1.5rem; font-weight:700;">{stat.value}</div>
            <div style="font-family:'Cinzel',serif; color:#9a8060; font-size:0.8rem; letter-spacing:0.08em; text-transform:uppercase; font-weight:600;">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Timeline -->
    <div style="max-width:48rem; margin:0 auto; padding:5rem 1rem; position:relative;">
      {journeyMilestones.map((milestone, i) => (
        <div id={milestone.title.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/(^-|-$)/g,'')} class={i % 2 === 0 ? 'reveal-left' : 'reveal-right'} style={`display:flex; align-items:flex-start; gap:1.5rem; margin-bottom:3rem; ${i % 2 === 1 ? 'flex-direction:row-reverse;' : ''}`}>
          <div style="width:3.5rem;height:3.5rem;border-radius:50%;background:linear-gradient(135deg,#231a0e,#1a1208);border:2px solid #3d2e18;display:flex;align-items:center;justify-content:center;flex-shrink:0;z-index:1;position:relative;">
            <Fragment set:html={milestone.icon} />
          </div>
          <div class="parchment-card corner-ornament" style="flex:1;padding:1.25rem;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
              <h2 style="font-family:'Cinzel',serif;color:#f0c040;font-size:1rem;font-weight:700;">{milestone.title}</h2>
              <span style="font-size:0.7rem;color:#c9a227;font-family:'Cinzel',serif;white-space:nowrap;display:inline-flex;align-items:center;gap:0.25rem;">
                <svg width="10" height="13" viewBox="0 0 10 13" fill="white" xmlns="http://www.w3.org/2000/svg">
                  <path d="M5 0C2.24 0 0 2.24 0 5c0 3.75 5 8 5 8s5-4.25 5-8c0-2.76-2.24-5-5-5zm0 6.5A1.5 1.5 0 1 1 5 3.5a1.5 1.5 0 0 1 0 3z"/>
                </svg>
                {milestone.location}
              </span>
            </div>
            <p style="color:#c9a96e;font-size:0.875rem;line-height:1.7;margin-bottom:0.75rem;">{milestone.description}</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.4rem;">
              {milestone.tags.map(tag => (
                <span style="font-size:0.75rem;padding:0.15rem 0.5rem;border:1px solid #6b5a3e;color:#9a8060;font-family:'Cinzel',serif;letter-spacing:0.05em;text-transform:uppercase;font-weight:500;">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}

      <!-- What's next -->
      <div class="reveal-rotate" style="display:flex;align-items:flex-start;gap:1.5rem;">
        <div style="width:3.5rem;height:3.5rem;border-radius:50%;border:2px dashed #3d2e18;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;opacity:0.4;">?</div>
        <div class="parchment-card" style="flex:1;padding:1.25rem;border-style:dashed;">
          <h2 style="font-family:'Cinzel',serif;color:#9a8060;font-size:1rem;font-weight:700;margin-bottom:0.5rem;">The Next Chapter...</h2>
          <p style="color:#6b5a3e;font-style:italic;font-size:0.875rem;">
            The Rift beneath Velento stirs. The Five Stones to banish Bane must be found. Strahd von Zarovich — the first vampire — holds one. Whatever comes next — it won't be boring.
          </p>
        </div>
      </div>
    </div>

    <!-- Realm Map -->
    <div class="reveal-scale" style="max-width:72rem;margin:0 auto;padding:0 1rem 5rem;">
      <div style="text-align:center;margin-bottom:1rem;">
        <p style="font-family:'Cinzel',serif;color:#c9a227;font-size:0.75rem;letter-spacing:0.3em;text-transform:uppercase;margin-bottom:0.5rem;">The Known World</p>
        <h3 style="font-family:'Cinzel Decorative',serif;color:#f0c040;font-size:1.5rem;font-weight:700;" class="text-glow-gold">The Realm Map</h3>
      </div>
      <div style="display:flex; align-items:center; gap:0.75rem; justify-content:center;">
        <div class="map-zoom-wrap">
          <img src="/map.png" alt="Map of the Realm" class="map-zoom-img"/>
        </div>
        <div class="map-zoom-controls">
          <button class="map-zoom-btn" data-zoom="in"  aria-label="Zoom in">+</button>
          <button class="map-zoom-btn" data-zoom="reset" aria-label="Reset">⌖</button>
          <button class="map-zoom-btn" data-zoom="out" aria-label="Zoom out">−</button>
        </div>
      </div>
    </div>

</Layout>

<style>
/* ── Constellation map ─────────────────────── */
.constell-svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

.constell {
  opacity: 0;
  animation: constellFade var(--dur) ease-in-out var(--delay) infinite;
}

@keyframes constellFade {
  0%   { opacity: 0; }
  5%   { opacity: 1; }
  75%  { opacity: 0.9; }
  92%  { opacity: 0; }
  100% { opacity: 0; }
}

.cline {
  stroke: rgba(240, 192, 64, 0.45);
  stroke-width: 0.5;
  stroke-dasharray: 3 3;
}

.cstar {
  fill: #f0c040;
}
.pa { animation: cPulse 2.8s ease-in-out infinite alternate; }
.pb { animation: cPulse 3.5s ease-in-out 1s infinite alternate; }
.pc { animation: cPulse 2.2s ease-in-out 1.8s infinite alternate; }

@keyframes cPulse {
  0%   { opacity: 0.5; filter: drop-shadow(0 0 2px rgba(240,192,64,0.5)); }
  100% { opacity: 1;   filter: drop-shadow(0 0 6px rgba(255,220,80,1)); }
}

.lone {
  fill: #c9a227;
  opacity: 0;
  animation: lonePulse 7s ease-in-out var(--ld, 0s) infinite;
}

@keyframes lonePulse {
  0%, 100% { opacity: 0; }
  20%, 80%  { opacity: 0.55; filter: drop-shadow(0 0 4px rgba(201,162,39,0.8)); }
}

@media (max-width: 640px) {
  .header-deco-img { display: none; }
  .deco-mobile-show { display: block; width: 55vw; }
  .stats-grid { grid-template-columns: repeat(2, 1fr) !important; }
  .stats-grid > *:last-child:nth-child(odd) { grid-column: 1 / -1; }
}
</style>
