---
import Layout from '../../layouts/Layout.astro';
import { oneShots } from '../../data/oneshots';
---

<Layout title="The Forgotten Tomes" description="One-shots from the world of the Motley Marauders.">

  <div style="padding:5rem 1rem 3rem; text-align:center; border-bottom:1px solid #3d2e18; position:relative; overflow:hidden;">
    <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.75rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:1rem; position:relative; z-index:1;">Side Stories</p>
    <h1 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:clamp(2rem,5vw,3.5rem); font-weight:700; position:relative; z-index:1;" class="text-glow-gold">The Forgotten Tomes</h1>
    <div class="rune-divider" style="max-width:16rem; margin:1.5rem auto 0; position:relative; z-index:1;"></div>
    <p style="color:#c9a96e; font-style:italic; margin-top:1rem; max-width:40rem; margin-left:auto; margin-right:auto; position:relative; z-index:1;">
      Tales that run beside the main campaign — one-shots, side quests, and chapters that live in their own light.
    </p>
  </div>

  <div style="max-width:64rem; margin:0 auto; padding:4rem 1rem;">
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr)); gap:1.5rem;">
      {oneShots.map((shot, i) => (
        <a href={`/forgotten-tomes/${shot.slug}`} class="parchment-card reveal" style={`display:block; text-decoration:none; padding:2rem 1.5rem; transition:border-color 0.2s, transform 0.2s; transition-delay:${i*0.06}s;`} onmouseover="this.style.borderColor='#c9a227';this.style.transform='translateY(-4px)'" onmouseout="this.style.borderColor='';this.style.transform=''">
          <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.65rem; letter-spacing:0.3em; text-transform:uppercase; margin-bottom:0.75rem;">One-Shot</p>
          <h2 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:1.1rem; font-weight:700; margin-bottom:0.75rem; line-height:1.3;">{shot.title}</h2>
          <p style="font-family:'IM Fell English',serif; color:#9a8060; font-style:italic; font-size:0.9rem; line-height:1.5;">{shot.tagline}</p>
          <div style="margin-top:1.5rem;">
            <span class="site-btn">Unseal the Tome →</span>
          </div>
        </a>
      ))}
    </div>
  </div>

</Layout>
