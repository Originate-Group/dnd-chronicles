---
import Layout from '../layouts/Layout.astro';
import { characters, companions } from '../data/characters';
---

<Layout title="The Party" description="Meet the Motley Marauders — character bios, stats, and portraits.">

  <!-- Page header -->
  <div style="padding:5rem 1rem 3rem; text-align:center; border-bottom:1px solid #3d2e18;">
    <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.75rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:1rem;">Roll for Initiative</p>
    <h1 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:clamp(2rem,5vw,3.5rem); font-weight:700;" class="text-glow-gold">
      The Party
    </h1>
    <div class="rune-divider" style="max-width:16rem; margin:1.5rem auto 0;"></div>
    <p style="color:#c9a96e; font-style:italic; margin-top:1rem; max-width:40rem; margin-left:auto; margin-right:auto;">
      Eleven adventurers. One very chaotic campaign.
    </p>

    <!-- Quick-jump nav -->
    <div style="display:flex; flex-wrap:wrap; gap:0.5rem; justify-content:center; margin-top:2rem;">
      {characters.map(c => (
        <a href={`#${c.name.toLowerCase().replace(/[\s()\/]/g,'-').replace(/-+/g,'-')}`}
          class={`badge-${c.classSlug}`}
          style="font-family:'Cinzel',serif; font-size:0.7rem; padding:0.25rem 0.6rem; border:1px solid; border-radius:9999px; text-decoration:none; white-space:nowrap;"
        >
          {c.name.split(' ')[0].split('(')[0].trim()}
        </a>
      ))}
    </div>
  </div>

  <!-- Characters -->
  <div style="max-width:72rem; margin:0 auto; padding:4rem 1rem;">
    {characters.map((char, i) => {
      const hpPercent = Math.round((char.hp / char.maxHp) * 100);
      const hpColor = hpPercent > 60 ? '#4ade80' : hpPercent > 25 ? '#facc15' : '#f87171';
      const anchorId = char.name.toLowerCase().replace(/[\s()\/]/g,'-').replace(/-+/g,'-');
      return (
        <article
          id={anchorId}
          class="parchment-card"
          style={`margin-bottom:3rem; overflow:hidden; border-left:3px solid ${i % 2 === 0 ? '#8b0000' : '#c9a227'};`}
        >
          <!-- Top section: portrait + identity + stats -->
          <div style="display:grid; grid-template-columns:auto 1fr; gap:0;">

            <!-- Portrait -->
            <div style="width:200px; flex-shrink:0; position:relative; overflow:hidden; background:#1a1208;">
              {char.image ? (
                <img
                  src={char.image}
                  alt={char.name}
                  style="width:200px; height:260px; object-fit:cover; object-position:top; display:block; filter:sepia(20%) contrast(1.05);"
                />
              ) : (
                <div style="width:200px; height:260px; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,#1a1208,#231a0e);">
                  <span style="font-size:4rem; opacity:0.4;">{char.icon}</span>
                </div>
              )}
              <!-- Gradient overlay at bottom of portrait -->
              <div style="position:absolute; bottom:0; left:0; right:0; height:60px; background:linear-gradient(to top, #1a1208, transparent);"></div>
            </div>

            <!-- Identity + stat block -->
            <div style="padding:1.5rem; display:flex; flex-direction:column; gap:1rem;">

              <!-- Name row -->
              <div>
                <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap; margin-bottom:0.4rem;">
                  <h2 style="font-family:'Cinzel',serif; color:#f0c040; font-size:1.4rem; font-weight:700; line-height:1.1;">{char.name}</h2>
                  {char.conditions?.map(cond => (
                    <span style="font-size:0.65rem; padding:0.15rem 0.5rem; border:1px solid #8b0000; color:#f87171; font-family:'Cinzel',serif; letter-spacing:0.05em; text-transform:uppercase; animation:flicker 2s ease-in-out infinite;">
                      ⚠ {cond}
                    </span>
                  ))}
                </div>
                <p style="font-size:0.8rem; color:#6b5a3e; font-family:'Cinzel',serif;">Player: {char.player}</p>
              </div>

              <!-- Class/Race badges -->
              <div style="display:flex; flex-wrap:wrap; gap:0.4rem; align-items:center;">
                <span class={`badge-${char.classSlug}`} style="font-family:'Cinzel',serif; font-size:0.7rem; padding:0.2rem 0.6rem; border:1px solid; border-radius:9999px;">
                  {char.class}
                </span>
                <span style="font-size:0.7rem; color:#c9a96e; font-family:'Cinzel',serif; padding:0.2rem 0.6rem; border:1px solid #3d2e18; border-radius:9999px;">
                  {char.race}
                </span>
                <span style="font-size:0.7rem; color:#6b5a3e; font-family:'Cinzel',serif; padding:0.2rem 0.6rem; border:1px solid #3d2e18; border-radius:9999px;">
                  Level {char.level}
                </span>
                {char.subclass && (
                  <span style="font-size:0.65rem; color:#6b5a3e; font-style:italic; font-family:'IM Fell English',serif;">
                    {char.subclass}
                  </span>
                )}
              </div>

              <!-- HP bar -->
              <div>
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.3rem;">
                  <span style="font-family:'Cinzel',serif; font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase; color:#6b5a3e;">Hit Points</span>
                  <span style="font-family:'Cinzel',serif; font-size:0.8rem; color:{hpColor};">{char.hp} / {char.maxHp}</span>
                </div>
                <div style="height:6px; background:#1a1208; border:1px solid #3d2e18; border-radius:3px; overflow:hidden;">
                  <div style={`height:100%; width:${hpPercent}%; background:${hpColor}; transition:width 0.3s; border-radius:3px;`}></div>
                </div>
              </div>

              <!-- Stat grid -->
              <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(80px,1fr)); gap:0.5rem;">
                {[
                  { label: 'AC', value: char.ac },
                  { label: 'P. Perc.', value: char.passivePerception },
                  { label: 'P. Invest.', value: char.passiveInvestigation },
                  { label: 'P. Insight', value: char.passiveInsight },
                  ...(char.darkvision ? [{ label: 'Darkvision', value: `${char.darkvision}ft` }] : []),
                ].map(stat => (
                  <div style="text-align:center; background:rgba(0,0,0,0.2); border:1px solid #3d2e18; padding:0.4rem 0.25rem; border-radius:2px;">
                    <div style="font-family:'Cinzel',serif; font-size:1rem; font-weight:700; color:#f0c040; line-height:1;">{stat.value}</div>
                    <div style="font-family:'Cinzel',serif; font-size:0.55rem; letter-spacing:0.05em; text-transform:uppercase; color:#6b5a3e; margin-top:0.2rem; line-height:1.2;">{stat.label}</div>
                  </div>
                ))}
              </div>

            </div>
          </div>

          <!-- Divider -->
          <div class="rune-divider" style="margin:0 1.5rem;"></div>

          <!-- Bio + Quote -->
          <div style="padding:1.5rem; display:grid; grid-template-columns:1fr auto; gap:2rem; align-items:start;">
            <div>
              <h3 style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.75rem; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:0.75rem;">Background</h3>
              <p style="color:#c9a96e; line-height:1.8; font-size:0.95rem;">{char.bio}</p>
            </div>

            <blockquote class="dnd-quote" style="max-width:260px; flex-shrink:0;">
              <p style="font-size:0.9rem;">"{char.quote}"</p>
              <footer style="margin-top:0.5rem; font-style:normal; font-family:'Cinzel',serif; font-size:0.75rem; color:#c9a227;">— {char.name.split(' ')[0]}</footer>
            </blockquote>
          </div>

        </article>
      );
    })}

    <!-- Boblin companion section -->
    {companions.length > 0 && (
      <div style="margin-top:2rem;">
        <div class="rune-divider" style="margin-bottom:2rem;">
          <span style="font-family:'Cinzel',serif; color:#6b5a3e; font-size:0.75rem; letter-spacing:0.2em; text-transform:uppercase; white-space:nowrap; padding:0 1rem;">
            Party Companions
          </span>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px,1fr)); gap:1.5rem;">
          {companions.map(companion => (
            <div class="parchment-card" style="overflow:hidden;">
              {companion.image && (
                <img
                  src={companion.image}
                  alt={companion.name}
                  style="width:100%; height:200px; object-fit:cover; object-position:top; filter:sepia(20%) contrast(1.05);"
                />
              )}
              <div style="padding:1rem;">
                <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.5rem;">
                  <h3 style="font-family:'Cinzel',serif; color:#f0c040; font-size:1rem; font-weight:700;">{companion.name}</h3>
                  <span style="font-size:0.65rem; padding:0.15rem 0.5rem; border:1px solid #6b5a3e; color:#6b5a3e; font-family:'Cinzel',serif; border-radius:9999px;">
                    {companion.type}
                  </span>
                </div>
                <p style="font-size:0.85rem; color:#c9a96e; font-style:italic; margin-bottom:0.75rem;">{companion.description}</p>
                {companion.quote && (
                  <blockquote class="dnd-quote" style="margin-top:0.5rem;">
                    <p style="font-size:0.8rem;">"{companion.quote}"</p>
                  </blockquote>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </div>

</Layout>

<style>
  /* Responsive: stack portrait on mobile */
  @media (max-width: 640px) {
    article > div[style*="grid-template-columns:auto 1fr"] {
      grid-template-columns: 1fr !important;
    }
    article > div img {
      width: 100% !important;
      height: 220px !important;
    }
  }
</style>
