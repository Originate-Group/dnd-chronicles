---
import Layout from '../layouts/Layout.astro';
import { magicItems, mysteriousItems, generalItems, partyGold } from '../data/inventory';

const activeItems = magicItems.filter(i => i.status === 'active');
const usedItems   = magicItems.filter(i => i.status !== 'active');

const rarityColour: Record<string, string> = {
  'Common':    '#9a8060',
  'Uncommon':  '#6ee7b7',
  'Rare':      '#60a5fa',
  'Very Rare': '#c084fc',
  'Legendary': '#f0c040',
  'Unknown':   '#9a8060',
};

// Vector SVG icons keyed by iconKey
const icons: Record<string, string> = {
  sword:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="16"/><line x1="8.5" y1="9" x2="15.5" y2="9"/><path d="M10 16h4"/><path d="M11 16l-1.5 4M13 16l1.5 4"/></svg>`,
  ring:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="13" r="7"/><path d="M9 6.5C9 4.6 10.3 3 12 3s3 1.6 3 3.5" stroke-width="1.5"/><circle cx="12" cy="5.5" r="1.5" fill="currentColor" stroke="none"/></svg>`,
  wand:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="20" x2="16" y2="8"/><circle cx="18.5" cy="5.5" r="3.5"/><path d="M16 4c1-1.5 4 0 4 3M17 7c.5 1.5 2.5 1.5 3 0"/></svg>`,
  mace:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="8" cy="8" r="5"/><path d="M5.5 5.5l5 5"/><path d="M11.5 11.5L20 20"/><path d="M5 8h6M8 5v6"/></svg>`,
  shield:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
  cloak:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3h8"/><path d="M8 3C6 8 4 12 4 17c0 2 1.5 3 4 3"/><path d="M16 3c2 5 4 9 4 14 0 2-1.5 3-4 3"/><path d="M8 20c1-2 3-3 4-3s3 1 4 3"/><path d="M12 3v5"/></svg>`,
  rope:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 8c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/><path d="M3 12c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/><path d="M3 16c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/></svg>`,
  necklace: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M7 8a5 5 0 0110 0"/><path d="M7 8L5 17"/><path d="M17 8l2 9"/><path d="M5 17a7 7 0 0014 0"/><circle cx="12" cy="20" r="2" fill="currentColor" stroke="none"/></svg>`,
  leaf:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8C17 8 17 18 12 21 7 18 7 8 7 8c0 0 1.5-5 5-5s5 5 5 5z"/><path d="M12 21V11"/></svg>`,
  gem:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12l4 6-10 12L2 9z"/><path d="M2 9h20"/><path d="M12 21V9"/><path d="M6 3l3 6M18 3l-3 6"/></svg>`,
  book:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/><path d="M8 7h8M8 11h6"/></svg>`,
  pearl:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M9 9a4 4 0 016 0"/><path d="M7 14a6 6 0 0010 0"/></svg>`,
  stone:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 3C7.5 3 4 7 4 11.5S7.5 21 12 21s8-4.5 8-9.5S16.5 3 12 3z"/><path d="M8 10c1-2 5-3 7 0"/><path d="M8 14c1 2 6 3 8 1"/></svg>`,
  onyx:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 9l2 11h14l2-11z"/><path d="M3 9h18"/><path d="M12 2l3 7M12 2l-3 7"/><path d="M12 20v-4"/></svg>`,
  feather:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.24 12.24a6 6 0 00-8.49-8.49L5 10.5V19h8.5z"/><path d="M16 8L2 22"/><path d="M17 15H9"/></svg>`,
  coin:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v10"/><path d="M9 10h6M9 14h5"/></svg>`,
  envelope: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>`,
  mushroom: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 11C4 7 7.6 4 12 4s8 3 8 7z"/><path d="M9.5 11v8a2.5 2.5 0 005 0v-8"/><path d="M8 14h8"/></svg>`,
  bottle:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2h4v3l2 3v11a2 2 0 01-2 2H10a2 2 0 01-2-2V8l2-3V2z"/><path d="M8 14h8"/></svg>`,
  tree:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-8"/><path d="M17 10l-5-8-5 8h3l-2 4h8l-2-4h3z"/></svg>`,
  crest:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 7v6c0 5 4 8.5 9 10 5-1.5 9-5 9-10V7z"/><path d="M8 12l2.5 2.5L16 9"/></svg>`,
  hairpin:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="12" y1="3" x2="12" y2="21"/><path d="M8 7l4-4 4 4"/><circle cx="12" cy="14" r="2"/></svg>`,
  eye:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="1" fill="currentColor" stroke="none"/></svg>`,
  scroll:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8L14 2z"/><path d="M14 2v6h6"/><path d="M8 13h8M8 17h5"/></svg>`,
  potion:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6M10 3v4L6 13v6a1 1 0 001 1h10a1 1 0 001-1v-6l-4-6V3"/><path d="M6 17h12"/></svg>`,
  rope2:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 5c4 0 4 4 8 4s4-4 8-4"/><path d="M5 19c4 0 4-4 8-4s4 4 8 4"/><path d="M5 5v14M21 5v14"/></svg>`,
  tools:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`,
  fire:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c0 0 5 4 5 10a5 5 0 01-10 0c0-3 1-5 2-7 0 2.5 1 3.5 3 4.5 0-2.5 1-5.5 0-7.5z"/></svg>`,
  web:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="9"/><path d="M12 3v18M3 12h18"/><path d="M5.6 5.6l12.8 12.8M18.4 5.6L5.6 18.4"/><ellipse cx="12" cy="12" rx="4" ry="9"/></svg>`,
  pack:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-8 0v2"/><circle cx="12" cy="7" r="4"/><path d="M4 21h16"/><path d="M9 11l3 3 3-3"/></svg>`,
  torch:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c0 0 2 2 2 5s-2 4-2 4-2-1-2-4 2-5 2-5z"/><rect x="10" y="11" width="4" height="10" rx="1"/><path d="M10 16h4"/></svg>`,
  hammer:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 12l-8.5 8.5a2.12 2.12 0 01-3-3L12 9"/><path d="M17.64 15L22 10.64"/><path d="M20.91 11.7L19.24 7.74a2 2 0 00-2.66-1l-3 1.3 4.5 6z"/></svg>`,
  hook:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 2v12"/><path d="M12 14a5 5 0 010 10H9"/><path d="M9 24a3 3 0 010-4"/></svg>`,
  pill:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.5 20.5l-7-7a5 5 0 017-7l7 7a5 5 0 01-7 7z"/><path d="M8.5 11.5l5 5"/></svg>`,
  box:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12"/></svg>`,
  bomb:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="13" r="8"/><path d="M14 4l2-2 4 4-2 2"/><path d="M16 6l-3.5 3.5"/><path d="M19 4l2-2"/></svg>`,
  key:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="5.5"/><path d="M21 2L11.5 11.5"/><path d="M15.5 7.5L21 13l-2.5 2.5-5.5-5.5"/></svg>`,
};

// Map iconKey from data to icon lookup key
const iconMap: Record<string, string> = {
  'Cloak of Arachnida':       'cloak',
  'Wand of Fireballs':        'wand',
  'Luck Blade':               'sword',
  'Ring of Regeneration':     'ring',
  'Mace of Disruption':       'mace',
  'Bracers of Defence':       'shield',
  'Rope of Entanglement':     'rope',
  'Necklace of Adaptation':   'necklace',
  'Ring of Water Walking':    'ring',
  'Ring of Protection':       'ring',
  'Nature Mantle':            'leaf',
  'Pearls of Power':          'pearl',
  'Stone of Good Luck':       'stone',
  'Ring of Intelligence':     'ring',
  'Night Onyx':               'onyx',
  'Tome of Wisdom':           'book',
  'Raven Feather':            'feather',
  'Pirate Coin':              'coin',
  'Envelope':                 'envelope',
  'Small Shield':             'shield',
  'Hairpin':                  'hairpin',
  'Mushroom':                 'mushroom',
  'Bottle':                   'bottle',
  'Tree Sample':              'tree',
  'Crest':                    'crest',
  'Leatherbound Book':        'book',
  'Moving Eye':               'eye',
  'Healing Potion':           'potion',
  'Greater Healing Potion':   'potion',
  "Rope (50ft)":              'rope',
  'Torch':                    'torch',
  'Rations (days)':           'pack',
  "Thieves' Tools":           'tools',
  'Tinderbox':                'box',
  'Crowbar':                  'hammer',
  'Grappling Hook':           'hook',
  'Antitoxin':                'pill',
  'Scroll of Dispel Magic':   'scroll',
  'Gunpowder':                'bomb',
};
---

<Layout title="Party Inventory" description="Everything the Motley Marauders carry — magic, mysterious, and mundane.">

  <!-- Page header -->
  <div style="padding:5rem 1rem 3rem; text-align:center; border-bottom:1px solid #3d2e18; position:relative; overflow:hidden;">

    <div class="header-deco-img" style="position:absolute; right:0; bottom:0; top:0; width:clamp(180px,28vw,360px); pointer-events:none; z-index:0;">
      <img src="/bag-of-holding.png" alt="" style="width:100%; height:100%; object-fit:cover; object-position:center top; opacity:0.6; mask-image:linear-gradient(to left, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%); -webkit-mask-image:linear-gradient(to left, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);"/>
    </div>
    <div class="header-deco-img" style="position:absolute; left:0; bottom:0; top:0; width:clamp(180px,28vw,360px); pointer-events:none; z-index:0;">
      <img src="/gold.png" alt="" style="width:100%; height:100%; object-fit:cover; object-position:center top; opacity:0.6; mask-image:linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%); -webkit-mask-image:linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);"/>
    </div>

    <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.75rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:1rem; position:relative; z-index:1;">The Bag of Holding</p>
    <h1 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:clamp(2rem,5vw,3.5rem); font-weight:700; position:relative; z-index:1;" class="text-glow-gold">Party Inventory</h1>
    <div class="rune-divider" style="max-width:16rem; margin:1.5rem auto 0; position:relative; z-index:1;"></div>
    <p style="color:#c9a96e; font-style:italic; margin-top:1rem; max-width:40rem; margin-left:auto; margin-right:auto; position:relative; z-index:1;">
      Everything looted, gifted, and questionably acquired.
    </p>
  </div>

  <div style="max-width:72rem; margin:0 auto; padding:4rem 1rem;">

    <!-- Gold tracker -->
    <div class="parchment-card reveal-scale" style="max-width:24rem; margin:0 auto 3rem; padding:1.5rem 2.5rem; text-align:center;">
      <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.85rem; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:0.5rem;">Party Treasury</p>
      <div style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:2.5rem; font-weight:700; line-height:1;">{partyGold.toLocaleString()} <span style="font-size:1.2rem; color:#c9a227;">gp</span></div>
    </div>

    <!-- ── General Items ───────────────────────────────────── -->
    <section class="reveal" style="margin-bottom:4rem;">
      <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem; border-bottom:1px solid #3d2e18; padding-bottom:1rem;">
        <h2 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:1.3rem; font-weight:700; flex:1;">General Items</h2>
        <span style="font-family:'Cinzel',serif; font-size:0.75rem; color:#6b5a3e;">{generalItems.length} items</span>
      </div>

      <div style="display:grid; gap:0.5rem;">
        {generalItems.map((item, i) => (
          <div class="parchment-card reveal" style={`padding:0.75rem 1.25rem; display:grid; grid-template-columns:2rem 1fr auto auto; align-items:center; gap:1rem; transition-delay:${i*0.03}s;`}>
            <span style="color:#c9a227; display:flex; align-items:center; justify-content:center;" set:html={icons[iconMap[item.name] ?? 'box']?.replace('<svg', '<svg width="20" height="20"') ?? ''}></span>
            <div>
              <span style="font-family:'Cinzel',serif; color:#e8d5b0; font-size:0.9rem; font-weight:600;">{item.name}</span>
              {item.notes && <p style="font-size:0.75rem; color:#6b5a3e; font-style:italic; margin-top:0.1rem;">{item.notes}</p>}
            </div>
            <span style="font-family:'Cinzel',serif; color:#f0c040; font-size:0.95rem; font-weight:700; min-width:1.5rem; text-align:center;">{item.quantity}</span>
            <span style={`font-family:'Cinzel',serif; font-size:0.7rem; text-transform:uppercase; letter-spacing:0.05em; text-align:right; min-width:5rem; ${item.holder==='Unassigned' ? 'color:#6b5a3e; font-style:italic;' : 'color:#c9a227;'}`}>{item.holder}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Magic Items Carousel ───────────────────────────── -->
    <section class="reveal" style="margin-bottom:4rem;">
      <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem; border-bottom:1px solid #3d2e18; padding-bottom:1rem;">
        <h2 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:1.3rem; font-weight:700; flex:1;">Magic Items</h2>
        <span style="font-family:'Cinzel',serif; font-size:0.75rem; color:#6b5a3e;">{activeItems.length} items</span>
      </div>

      <div class="inv-carousel-outer">
        <button class="inv-carousel-btn" id="magic-prev" aria-label="Previous">&#8249;</button>
        <div class="inv-carousel-mask">
          <div class="inv-carousel-viewport" id="magic-viewport">
            <div class="inv-carousel-track" id="magic-track">
              {activeItems.map((item) => (
                <div class="inv-card parchment-card">
                  <h3 style="font-family:'Cinzel',serif; color:#f0c040; font-size:0.8rem; font-weight:700; margin-bottom:0.4rem; text-align:center; line-height:1.3;">{item.name}</h3>
                  <div style="text-align:center; margin-bottom:0.6rem;">
                    <span style={`font-family:'Cinzel',serif; font-size:0.6rem; padding:0.1rem 0.4rem; border:1px solid ${rarityColour[item.rarity]}44; border-radius:9999px; color:${rarityColour[item.rarity]};`}>{item.rarity}</span>
                  </div>
                  <p style="font-size:0.78rem; color:#c9a96e; line-height:1.5; text-align:center; margin-bottom:0.6rem;">{item.description}</p>
                  {item.notes && <p style="font-size:0.72rem; font-style:italic; color:#9a8060; text-align:center; margin-bottom:0.5rem;">{item.notes}</p>}
                  <div style="border-top:1px solid #2a1e0e; padding-top:0.5rem; text-align:center; margin-top:auto;">
                    <span style={`font-family:'Cinzel',serif; font-size:0.68rem; text-transform:uppercase; letter-spacing:0.05em; ${item.holder==='Unassigned' ? 'color:#6b5a3e; font-style:italic;' : 'color:#c9a227;'}`}>{item.holder}</span>
                    {item.dndBeyondUrl && (
                      <div style="margin-top:0.5rem;">
                        <a href={item.dndBeyondUrl} target="_blank" rel="noopener noreferrer" class="ddb-link">D&amp;D Beyond ↗</a>
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
        <button class="inv-carousel-btn" id="magic-next" aria-label="Next">&#8250;</button>
      </div>

      <!-- Consumed items -->
      {usedItems.length > 0 && (
        <div style="margin-top:1.5rem;">
          <p style="font-family:'Cinzel',serif; color:#6b5a3e; font-size:0.65rem; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:0.6rem;">Consumed</p>
          <div style="display:flex; flex-wrap:wrap; gap:0.5rem;">
            {usedItems.map(item => (
              <div class="parchment-card" style="padding:0.6rem 1rem; opacity:0.65; display:flex; align-items:center; gap:0.5rem;">
                <span style="font-family:'Cinzel',serif; color:#9a8060; font-size:0.8rem; text-decoration:line-through;">{item.name}</span>
                {item.notes && <span style="font-size:0.72rem; color:#6b5a3e; font-style:italic;">— {item.notes}</span>}
              </div>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- ── Mysterious Items Carousel ─────────────────────── -->
    <section class="reveal">
      <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem; border-bottom:1px solid #3d2e18; padding-bottom:1rem;">
        <h2 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:1.3rem; font-weight:700; flex:1;">Theodas' Treasure Room</h2>
        <span style="font-family:'Cinzel',serif; font-size:0.75rem; color:#6b5a3e;">{mysteriousItems.length} items</span>
      </div>
      <p style="color:#9a8060; font-style:italic; font-size:0.85rem; margin-bottom:1.5rem;">Twelve sealed cases. Some have already made their presence felt.</p>

      <div class="inv-carousel-outer">
        <button class="inv-carousel-btn" id="myst-prev" aria-label="Previous">&#8249;</button>
        <div class="inv-carousel-mask">
          <div class="inv-carousel-viewport" id="myst-viewport">
            <div class="inv-carousel-track" id="myst-track">
              {mysteriousItems.map((item) => (
                <div class={`inv-card parchment-card ${item.notes ? 'inv-card-flagged' : ''}`}>
                  <h3 style="font-family:'Cinzel',serif; color:#e8d5b0; font-size:0.8rem; font-weight:700; margin-bottom:0.6rem; text-align:center; line-height:1.3;">{item.name}</h3>
                  <p style="font-size:0.78rem; color:#c9a96e; line-height:1.5; text-align:center; margin-bottom:0.6rem;">{item.description}</p>
                  {item.notes && <p style="font-size:0.72rem; font-style:italic; color:#9a8060; border-left:2px solid #3d2e18; padding-left:0.4rem; margin-bottom:0.5rem; text-align:left;">{item.notes}</p>}
                  <div style="border-top:1px solid #2a1e0e; padding-top:0.5rem; text-align:center; margin-top:auto;">
                    <span style={`font-family:'Cinzel',serif; font-size:0.68rem; text-transform:uppercase; letter-spacing:0.05em; ${!item.holder || item.holder==='Unassigned' ? 'color:#6b5a3e; font-style:italic;' : 'color:#c9a227;'}`}>{item.holder ?? 'Unassigned'}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
        <button class="inv-carousel-btn" id="myst-next" aria-label="Next">&#8250;</button>
      </div>
    </section>

  </div>

  <script is:inline>
  (function () {
    function initCarousel(viewportId, prevId, nextId) {
      const viewport = document.getElementById(viewportId);
      const prev     = document.getElementById(prevId);
      const next     = document.getElementById(nextId);
      if (!viewport || !prev || !next) return;

      const track = viewport.querySelector('.inv-carousel-track');
      if (!track) return;

      const originals = Array.from(track.querySelectorAll('.inv-card'));
      const n = originals.length;

      const makeSet = () => {
        const frag = document.createDocumentFragment();
        originals.forEach(card => {
          const c = card.cloneNode(true);
          c.setAttribute('aria-hidden', 'true');
          frag.appendChild(c);
        });
        return frag;
      };

      track.appendChild(makeSet());
      track.insertBefore(makeSet(), track.firstChild);

      const GAP   = 12;
      const CARD_W = () => (track.children[0]?.offsetWidth ?? 190) + GAP;
      const setW   = () => n * CARD_W();

      let offset = setW();

      const setTransform = (px, animated) => {
        track.style.transition = animated
          ? 'transform 0.42s cubic-bezier(0.25,0.46,0.45,0.94)'
          : 'none';
        track.style.transform = `translateX(${-px}px)`;
        offset = px;
      };

      setTransform(offset, false);

      const normalise = () => {
        const s = setW();
        let o = offset;
        while (o >= 2 * s) o -= s;
        while (o < s)      o += s;
        if (o !== offset) setTransform(o, false);
      };

      let busy = false;
      const step = (dir) => {
        if (busy) return;
        busy = true;
        setTransform(offset + dir * CARD_W(), true);
        track.addEventListener('transitionend', function onEnd() {
          track.removeEventListener('transitionend', onEnd);
          normalise();
          busy = false;
        }, { once: true });
      };

      prev.addEventListener('click', () => step(-1));
      next.addEventListener('click', () => step(1));

      // Drag
      let dragStartX = null, dragStartOff = 0;
      const onDragStart = (x) => { dragStartX = x; dragStartOff = offset; track.style.transition = 'none'; };
      const onDragMove  = (x) => { if (dragStartX === null) return; const d = dragStartX - x; track.style.transform = `translateX(${-(dragStartOff + d)}px)`; offset = dragStartOff + d; };
      const onDragEnd   = () => {
        if (dragStartX === null) return;
        dragStartX = null;
        const cw = CARD_W();
        const snapped = Math.round(offset / cw) * cw;
        setTransform(snapped, true);
        track.addEventListener('transitionend', function onEnd() {
          track.removeEventListener('transitionend', onEnd);
          normalise();
          busy = false;
        }, { once: true });
      };

      viewport.addEventListener('mousedown', e => onDragStart(e.clientX));
      window.addEventListener('mousemove',   e => onDragMove(e.clientX));
      window.addEventListener('mouseup',         onDragEnd);
      viewport.addEventListener('touchstart', e => onDragStart(e.touches[0].clientX), { passive: true });
      viewport.addEventListener('touchmove',  e => onDragMove(e.touches[0].clientX),  { passive: true });
      viewport.addEventListener('touchend',       onDragEnd);
    }

    initCarousel('magic-viewport', 'magic-prev', 'magic-next');
    initCarousel('myst-viewport',  'myst-prev',  'myst-next');
  })();
  </script>

</Layout>

<style>
