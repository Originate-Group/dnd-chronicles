---
import Layout from '../layouts/Layout.astro';
import { magicItems, mysteriousItems, generalItems, partyGold } from '../data/inventory';

const activeItems = magicItems.filter(i => i.status === 'active');
const usedItems   = magicItems.filter(i => i.status !== 'active');

const rarityColour: Record<string, string> = {
  'Common':    '#9a8060',
  'Uncommon':  '#6ee7b7',
  'Rare':      '#60a5fa',
  'Very Rare': '#c084fc',
  'Legendary': '#f0c040',
  'Unknown':   '#9a8060',
};
---

<Layout title="Party Inventory" description="Everything the Motley Marauders carry — magic, mysterious, and mundane.">

  <!-- Page header -->
  <div style="padding:5rem 1rem 3rem; text-align:center; border-bottom:1px solid #3d2e18; position:relative; overflow:hidden;">

    <div class="header-deco-img" style="position:absolute; right:0; bottom:0; top:0; width:clamp(180px,28vw,360px); pointer-events:none; z-index:0;">
      <img src="/dungeon.jpg" alt="" style="width:100%; height:100%; object-fit:cover; object-position:center top; opacity:0.65; mask-image:linear-gradient(to left, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%); -webkit-mask-image:linear-gradient(to left, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);"/>
    </div>
    <div class="header-deco-img" style="position:absolute; left:0; bottom:0; top:0; width:clamp(180px,28vw,360px); pointer-events:none; z-index:0;">
      <img src="/library.jpg" alt="" style="width:100%; height:100%; object-fit:cover; object-position:center top; opacity:0.65; mask-image:linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%); -webkit-mask-image:linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);"/>
    </div>

    <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.75rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:1rem; position:relative; z-index:1;">The Bag of Holding</p>
    <h1 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:clamp(2rem,5vw,3.5rem); font-weight:700; position:relative; z-index:1;" class="text-glow-gold">
      Party Inventory
    </h1>
    <div class="rune-divider" style="max-width:16rem; margin:1.5rem auto 0; position:relative; z-index:1;"></div>
    <p style="color:#c9a96e; font-style:italic; margin-top:1rem; max-width:40rem; margin-left:auto; margin-right:auto; position:relative; z-index:1;">
      Everything looted, gifted, and questionably acquired. Holder allocation is an ongoing negotiation.
    </p>
  </div>

  <div style="max-width:72rem; margin:0 auto; padding:4rem 1rem;">

    <!-- Gold tracker -->
    <div class="parchment-card corner-ornament reveal-scale" style="max-width:28rem; margin:0 auto 4rem; padding:1.5rem; text-align:center;">
      <p style="font-family:'Cinzel',serif; color:#6b5a3e; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:0.5rem;">Party Treasury</p>
      <div style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:2.5rem; font-weight:700;">{partyGold.toLocaleString()} <span style="font-size:1.2rem; color:#c9a227;">gp</span></div>
      <p style="font-size:0.8rem; color:#6b5a3e; font-style:italic; margin-top:0.5rem;">Update partyGold in inventory.ts</p>
    </div>

    <!-- Magic Items -->
    <section class="reveal" style="margin-bottom:4rem;">
      <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem; border-bottom:1px solid #3d2e18; padding-bottom:1rem;">
        <h2 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:1.4rem; font-weight:700; flex:1;">Magic Items</h2>
        <span style="font-family:'Cinzel',serif; font-size:0.75rem; color:#6b5a3e; letter-spacing:0.1em;">{activeItems.length} items</span>
      </div>

      <div style="display:grid; gap:1rem; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr));">
        {activeItems.map((item, i) => (
          <div class="parchment-card reveal-scale" style={`padding:1.25rem; transition-delay:${i * 0.04}s;`}>

            <!-- Header row -->
            <div style="display:flex; align-items:flex-start; gap:0.75rem; margin-bottom:0.75rem;">
              <span style="font-size:1.5rem; line-height:1; flex-shrink:0;">{item.icon ?? '✦'}</span>
              <div style="flex:1; min-width:0;">
                <h3 style="font-family:'Cinzel',serif; color:#f0c040; font-size:0.95rem; font-weight:700; margin-bottom:0.3rem; line-height:1.3;">{item.name}</h3>
                <div style="display:flex; align-items:center; gap:0.4rem; flex-wrap:wrap;">
                  <span style={`font-family:'Cinzel',serif; font-size:0.6rem; padding:0.1rem 0.45rem; border:1px solid ${rarityColour[item.rarity]}33; border-radius:9999px; color:${rarityColour[item.rarity]}; background:${rarityColour[item.rarity]}11;`}>{item.rarity}</span>
                  <span style="font-family:'Cinzel',serif; font-size:0.6rem; color:#6b5a3e; text-transform:uppercase; letter-spacing:0.05em;">{item.type}</span>
                </div>
              </div>
            </div>

            <!-- Description -->
            <p style="font-size:0.875rem; color:#c9a96e; line-height:1.6; margin-bottom:0.75rem;">{item.description}</p>

            {item.notes && (
              <p style="font-size:0.8rem; font-style:italic; color:#9a8060; margin-bottom:0.75rem;">{item.notes}</p>
            )}

            <!-- Holder -->
            <div style="display:flex; align-items:center; gap:0.4rem; border-top:1px solid #2a1e0e; padding-top:0.6rem; margin-top:auto;">
              <span style="font-size:0.75rem; color:#3d2e18;">⚔</span>
              <span style={`font-family:'Cinzel',serif; font-size:0.7rem; text-transform:uppercase; letter-spacing:0.05em; ${item.holder === 'Unassigned' ? 'color:#6b5a3e; font-style:italic;' : 'color:#c9a227;'}`}>
                {item.holder}
              </span>
            </div>
          </div>
        ))}
      </div>

      <!-- Consumed -->
      {usedItems.length > 0 && (
        <div style="margin-top:1.5rem;">
          <p style="font-family:'Cinzel',serif; color:#6b5a3e; font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; margin-bottom:0.75rem;">Consumed / Used</p>
          <div style="display:grid; gap:0.5rem; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr));">
            {usedItems.map(item => (
              <div class="parchment-card" style="padding:0.875rem; opacity:0.45; display:flex; align-items:center; gap:0.75rem;">
                <span style="font-size:1.1rem;">{item.icon ?? '✦'}</span>
                <div>
                  <span style="font-family:'Cinzel',serif; color:#9a8060; font-size:0.85rem; font-weight:700; text-decoration:line-through;">{item.name}</span>
                  {item.notes && <p style="font-size:0.75rem; color:#6b5a3e; font-style:italic; margin-top:0.1rem;">{item.notes}</p>}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- General Items -->
    <section class="reveal" style="margin-bottom:4rem;">
      <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem; border-bottom:1px solid #3d2e18; padding-bottom:1rem;">
        <h2 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:1.4rem; font-weight:700; flex:1;">General Items</h2>
        <span style="font-family:'Cinzel',serif; font-size:0.75rem; color:#6b5a3e; letter-spacing:0.1em;">{generalItems.length} items</span>
      </div>
      <p style="color:#9a8060; font-style:italic; font-size:0.875rem; margin-bottom:1.5rem;">Quantities and holders marked with ? are placeholders — update these after each session.</p>

      <div style="display:grid; gap:0.6rem;">
        {generalItems.map((item, i) => (
          <div class="parchment-card reveal" style={`padding:0.875rem 1.25rem; display:flex; align-items:center; gap:1rem; transition-delay:${i * 0.03}s;`}>
            <span style="font-size:1.2rem; flex-shrink:0; width:1.5rem; text-align:center;">{item.icon ?? '📦'}</span>
            <span style="font-family:'Cinzel',serif; color:#e8d5b0; font-size:0.9rem; font-weight:600; flex:1;">{item.name}</span>
            <span style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.875rem; font-weight:700; min-width:2rem; text-align:center;">{item.quantity}</span>
            <span style={`font-family:'Cinzel',serif; font-size:0.7rem; text-transform:uppercase; letter-spacing:0.05em; min-width:6rem; text-align:right; ${item.holder === 'Unassigned' ? 'color:#6b5a3e; font-style:italic;' : 'color:#c9a227;'}`}>{item.holder}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Mysterious Items -->
    <section class="reveal">
      <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem; border-bottom:1px solid #3d2e18; padding-bottom:1rem;">
        <h2 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:1.4rem; font-weight:700; flex:1;">Theodas' Treasure Room</h2>
        <span style="font-family:'Cinzel',serif; font-size:0.75rem; color:#6b5a3e; letter-spacing:0.1em;">{mysteriousItems.length} items</span>
      </div>
      <p style="color:#9a8060; font-style:italic; font-size:0.875rem; margin-bottom:1.5rem;">Twelve sealed cases. Some have already made their presence felt.</p>

      <div style="display:grid; gap:1rem; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr));">
        {mysteriousItems.map((item, i) => {
          const flagged = !!item.notes;
          return (
            <div class="parchment-card reveal-scale" style={`padding:1.25rem; transition-delay:${i * 0.04}s; ${flagged ? 'border-top:2px solid #c9a227;' : ''}`}>
              <div style="display:flex; align-items:flex-start; gap:0.75rem; margin-bottom:0.6rem;">
                <span style="font-size:1.4rem; line-height:1; flex-shrink:0;">{item.icon ?? '✦'}</span>
                <h3 style="font-family:'Cinzel',serif; color:#e8d5b0; font-size:0.95rem; font-weight:700; line-height:1.3;">{item.name}</h3>
              </div>
              <p style="font-size:0.875rem; color:#c9a96e; line-height:1.6; margin-bottom:0.75rem;">{item.description}</p>
              {item.notes && (
                <p style="font-size:0.8rem; font-style:italic; color:#9a8060; border-left:2px solid #3d2e18; padding-left:0.5rem; margin-bottom:0.75rem;">{item.notes}</p>
              )}
              <div style="display:flex; align-items:center; gap:0.4rem; border-top:1px solid #2a1e0e; padding-top:0.6rem;">
                <span style="font-size:0.75rem; color:#3d2e18;">⚔</span>
                <span style={`font-family:'Cinzel',serif; font-size:0.7rem; text-transform:uppercase; letter-spacing:0.05em; ${!item.holder || item.holder === 'Unassigned' ? 'color:#6b5a3e; font-style:italic;' : 'color:#c9a227;'}`}>
                  {item.holder ?? 'Unassigned'}
                </span>
              </div>
            </div>
          );
        })}
      </div>
    </section>

  </div>
</Layout>

<style>
@media (max-width: 640px) {
  .header-deco-img { display: none; }
}
</style>
