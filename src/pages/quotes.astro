---
import Layout from '../layouts/Layout.astro';
import { quotes } from '../data/story';
import { characters, companions } from '../data/characters';

// Group quotes by speaker
const bySpeaker = quotes.reduce((acc, q) => {
  if (!acc[q.speaker]) acc[q.speaker] = [];
  acc[q.speaker].push(q);
  return acc;
}, {} as Record<string, typeof quotes>);

// Map speaker names to character classSlug for badge styling
const speakerClass: Record<string, string> = {};
characters.forEach(c => {
  speakerClass[c.name] = c.classSlug;
  // Handle quoted nicknames in names
  const shortName = c.name.split('"')[0].trim();
  speakerClass[shortName] = c.classSlug;
});

// Build a lookup that includes companions (e.g. Boblin)
const speakerExtras: Record<string, { image?: string; subtitle?: string }> = {
  "The Great Protector": { image: "/great-protector.jpg", subtitle: "Greater Green Dragon" },
};

function findSpeakerImage(name: string): string | undefined {
  if (speakerExtras[name]?.image) return speakerExtras[name].image;
  const pc = characters.find(c => c.name === name);
  if (pc?.image) return pc.image;
  const npc = companions.find(c => c.name === name);
  return npc?.image;
}
function findSpeakerIcon(name: string): string | undefined {
  return characters.find(c => c.name === name)?.icon;
}
function findSpeakerSubtitle(name: string): string | undefined {
  return speakerExtras[name]?.subtitle;
}
---

<Layout title="Quotes" description="The best (and worst) things said by the Motley Marauders.">

  <!-- Page header -->
  <div style="padding:5rem 1rem 3rem; text-align:center; border-bottom:1px solid #3d2e18; position:relative; overflow:hidden;">

    <!-- Goblin Village — left side -->
    <div class="header-deco-img" style="position:absolute; left:0; bottom:0; top:0; width:clamp(180px,28vw,360px); pointer-events:none; z-index:0;">
      <img
        src="/goblin-village.jpg"
        alt="Goblin Village"
        style="width:100%; height:100%; object-fit:cover; object-position:center top; opacity:0.55; mask-image:linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%); -webkit-mask-image:linear-gradient(to right, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);"
      />
    </div>

    <!-- Great Protector — right side -->
    <div class="header-deco-img" style="position:absolute; right:0; bottom:0; top:0; width:clamp(180px,28vw,360px); pointer-events:none; z-index:0;">
      <img
        src="/great-protector.jpg"
        alt="The Great Protector"
        style="width:100%; height:100%; object-fit:cover; object-position:center top; opacity:0.55; mask-image:linear-gradient(to left, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%); -webkit-mask-image:linear-gradient(to left, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);"
      />
    </div>

    <!-- Star field -->
    <div class="star-field" aria-hidden="true">
      {Array.from({length: 80}).map((_, i) => {
        // Avoid the central text block (x: 20–80%, y: 20–80%)
        let x: number, y: number;
        do { x = Math.random() * 100; y = Math.random() * 100; }
        while (x > 20 && x < 80 && y > 20 && y < 80);
        return (
        <div class="star" style={`
          --x: ${x.toFixed(1)}%;
          --y: ${y.toFixed(1)}%;
          --size: ${1.5 + Math.random() * 3}px;
          --delay: ${Math.random() * 6}s;
          --dur: ${4 + Math.random() * 8}s;
          --drift-x: ${((Math.random() - 0.5) * 40).toFixed(1)}px;
          --drift-y: ${((Math.random() - 0.5) * 30).toFixed(1)}px;
          --twinkle-dur: ${1.5 + Math.random() * 3}s;
          --twinkle-delay: ${Math.random() * 4}s;
          --brightness: ${0.4 + Math.random() * 0.6};
        `}></div>
        );
      })}
    </div>
    <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.75rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:1rem;">Words to Live (and Die) By</p>
    <h1 style="font-family:'Cinzel Decorative',serif; color:#f0c040; font-size:clamp(2rem,5vw,3.5rem); font-weight:700;" class="text-glow-gold">
      The Quotebook
    </h1>
    <div class="rune-divider" style="max-width:16rem; margin:1.5rem auto 0;"></div>
    <p style="color:#c9a96e; font-style:italic; margin-top:1rem; max-width:40rem; margin-left:auto; margin-right:auto;">
      Collected utterances from the Motley Marauders — wise, foolish, and occasionally both at once.
    </p>
  </div>

  <!-- Rotating featured quote -->
  <div style="padding:4rem 1rem 0;">
    <div style="max-width:48rem; margin:0 auto;">
      <div id="rq-wrap" class="parchment-card corner-ornament reveal-scale" style="padding:2rem; border:1px solid #3d2e18; border-top:3px solid #c9a227; text-align:center;">
        <p style="font-family:'Cinzel',serif; color:#6b5a3e; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:1.5rem;">✦ Quote of the Campaign ✦</p>
        <blockquote>
          <p id="rq-text" style="font-family:'IM Fell English',serif; font-style:italic; color:#e8d5b0; font-size:1.4rem; line-height:1.6; margin-bottom:1rem;"></p>
          <footer id="rq-speaker" style="font-family:'Cinzel',serif; font-size:0.875rem; color:#c9a227;"></footer>
        </blockquote>
        <p id="rq-context" style="font-size:0.9rem; margin-top:1rem; font-style:italic; color:#c9a96e; font-weight:500;"></p>
      </div>
    </div>
  </div>

  <script define:vars={{ rqQuotes: quotes.map(q => ({ text: q.text, speaker: q.speaker, context: q.context || '' })) }}>
  (function () {
    const wrap    = document.getElementById('rq-wrap');
    const text    = document.getElementById('rq-text');
    const speaker = document.getElementById('rq-speaker');
    const context = document.getElementById('rq-context');
    const FADE    = 1400;
    const HOLD    = 5500;
    let idx = 0;

    function setQuote(q) {
      text.textContent    = '\u201C' + q.text + '\u201D';
      speaker.textContent = '\u2014 ' + q.speaker;
      context.textContent = q.context;
    }

    function cycle() {
      wrap.style.opacity = '0';
      setTimeout(() => {
        idx = (idx + 1) % rqQuotes.length;
        setQuote(rqQuotes[idx]);
        wrap.style.opacity = '1';
      }, FADE);
    }

    setQuote(rqQuotes[0]);
    setTimeout(() => { wrap.style.transition = 'opacity 1.4s ease'; }, 500);
    setInterval(cycle, HOLD + FADE);
  })();
  </script>

  <!-- All quotes -->
  <div style="max-width:72rem; margin:0 auto; padding:4rem 1rem;">

    <!-- Filter hint -->
    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem; flex-wrap:wrap;">
      <p style="font-family:'Cinzel',serif; color:#6b5a3e; font-size:0.8rem; letter-spacing:0.1em; text-transform:uppercase;">By Speaker:</p>
      {Object.keys(bySpeaker).map(speaker => {
        const slug = speakerClass[speaker] || 'fighter';
        const subtitle = findSpeakerSubtitle(speaker);
        const label = subtitle ?? speaker.split(' ')[0];
        const customStyle = subtitle
          ? "font-family:'Cinzel',serif; font-size:0.7rem; padding:0.2rem 0.6rem; border:1px solid #6ee7b7; border-radius:9999px; text-decoration:none; cursor:pointer; color:#6ee7b7;"
          : "font-family:'Cinzel',serif; font-size:0.7rem; padding:0.2rem 0.6rem; border:1px solid; border-radius:9999px; text-decoration:none; cursor:pointer;";
        return (
          <a href={`#${speaker.toLowerCase().replace(/\s+/g,'-')}`}
            class={subtitle ? '' : `badge-${slug}`}
            style={customStyle}
          >
            {label}
          </a>
        );
      })}
    </div>

    <!-- Quotes by speaker -->
    {Object.entries(bySpeaker).map(([speaker, speakerQuotes], si) => {
      const slug = speakerClass[speaker] || 'fighter';
      const char = characters.find(c => c.name === speaker) ?? companions.find(c => c.name === speaker) as any;
      return (
        <section id={speaker.toLowerCase().replace(/\s+/g,'-')} class={si % 2 === 0 ? 'reveal-left' : 'reveal-right'} style="margin-bottom:3rem;">
          <!-- Speaker header -->
          <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem;">
            {findSpeakerImage(speaker)
              ? <img src={findSpeakerImage(speaker)} alt={speaker} style="width:2.75rem; height:2.75rem; border-radius:50%; object-fit:cover; object-position:top; border:2px solid #3d2e18; flex-shrink:0;"/>
              : <div style="width:2.75rem; height:2.75rem; border-radius:50%; background:linear-gradient(135deg,#1a1208,#231a0e); border:2px solid #3d2e18; display:flex; align-items:center; justify-content:center; font-size:1.1rem; flex-shrink:0;">{findSpeakerIcon(speaker) ?? '⚔'}</div>
            }
            <h2 style="font-family:'Cinzel',serif; color:#f0c040; font-size:1.25rem; font-weight:700;">{speaker}</h2>
            {findSpeakerSubtitle(speaker) ? (
              <span style="font-family:'Cinzel',serif; font-size:0.7rem; padding:0.2rem 0.6rem; border:1px solid #6ee7b7; border-radius:9999px; color:#6ee7b7; white-space:nowrap;">
                {findSpeakerSubtitle(speaker)}
              </span>
            ) : (char as any)?.class || (char as any)?.type ? (
              <span class={`badge-${slug}`} style="font-family:'Cinzel',serif; font-size:0.7rem; padding:0.2rem 0.6rem; border:1px solid; border-radius:9999px;">
                {(char as any)?.class ?? (char as any)?.type}
              </span>
            ) : null}
          </div>

          <div style="display:grid; gap:1rem; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr));">
            {speakerQuotes.map((quote, qi) => (
              <div class="parchment-card reveal-scale" style={`padding:1.25rem; position:relative; transition-delay:${qi * 0.07}s;`}>
                {quote.session && (
                  <span style="position:absolute; top:0.75rem; right:0.75rem; font-family:'Cinzel',serif; font-size:0.75rem; color:#6b5a3e; letter-spacing:0.05em; font-weight:500;">
                    Session {quote.session}
                  </span>
                )}
                <blockquote class="dnd-quote" style="margin-bottom:0.75rem;">
                  <p style="font-size:1.1rem;">"{quote.text}"</p>
                </blockquote>
                <p style="font-size:0.9rem; font-style:italic; color:#c9a96e; font-weight:500; line-height:1.6;">{quote.context}</p>
              </div>
            ))}
          </div>
        </section>
      );
    })}

  </div>

</Layout>

<style>
.star-field {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.star {
  position: absolute;
  left: var(--x);
  top: var(--y);
  width: var(--size);
  height: var(--size);
  border-radius: 50%;
  background: radial-gradient(circle, #fff8c0 0%, #f0c040 50%, #c9a227 100%);
  opacity: var(--brightness);
  box-shadow: 0 0 calc(var(--size) * 2) calc(var(--size) * 0.5) rgba(240, 192, 64, 0.7);
  animation:
    starDrift var(--dur) ease-in-out var(--delay) infinite alternate,
    starTwinkle var(--twinkle-dur) ease-in-out var(--twinkle-delay) infinite;
}

@keyframes starDrift {
  0%   { transform: translate(0, 0); }
  100% { transform: translate(var(--drift-x), var(--drift-y)); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: var(--brightness); transform: scale(1); }
  40%       { opacity: calc(var(--brightness) * 0.2); transform: scale(0.6); }
  70%       { opacity: calc(var(--brightness) * 1.0); transform: scale(1.3); box-shadow: 0 0 calc(var(--size) * 4) calc(var(--size)) rgba(240, 192, 64, 0.8); }
}

/* Keep hero text above stars */
.star-field ~ * {
  position: relative;
  z-index: 1;
}

@media (max-width: 640px) {
  .header-deco-img { display: none; }
}
</style>
