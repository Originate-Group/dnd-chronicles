---
import Layout from '../layouts/Layout.astro';
import { characters } from '../data/characters';
import { storyUpdates, quotes } from '../data/story';

const latestSession = storyUpdates[storyUpdates.length - 1];
// quotes imported for rotating hero display
---

<Layout title="Home">

  <!-- Hero -->
  <section class="relative min-h-screen flex flex-col items-center justify-center text-center px-4 py-20 overflow-hidden">

    <!-- Background glow -->
    <div class="absolute inset-0 pointer-events-none" style="
      background:
        radial-gradient(ellipse at 20% 50%, rgba(139,0,0,0.08) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 30%, rgba(201,162,39,0.06) 0%, transparent 60%),
        radial-gradient(ellipse at 50% 100%, rgba(26,18,8,0.9) 0%, transparent 70%);
    "></div>

    <!-- Decorative rune ring -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style="opacity: 0.04;">
      <div style="width:32rem; height:32rem; border:1px solid #c9a227; border-radius:50%;"></div>
    </div>
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" style="opacity: 0.04;">
      <div style="width:24rem; height:24rem; border:1px solid #c9a227; border-radius:50%; transform:rotate(45deg);"></div>
    </div>

    <!-- Fire + smoke + embers -->
    <div class="smoke-container" aria-hidden="true">

      <!-- Base fire glow -->
      <div class="fire-glow"></div>

      <!-- Smoke wisps — warm amber/crimson -->
      <div class="smoke-wisp" style="--x:48%; --delay:0s;   --dur:7s;  --size:200px; --drift:-35px; --rot:-12deg; --blur:20px; --col-inner:rgba(255,100,20,0.30); --col-mid:rgba(200,50,10,0.18); --col-outer:rgba(80,20,0,0.08);"></div>
      <div class="smoke-wisp" style="--x:52%; --delay:1.2s; --dur:9s;  --size:260px; --drift:45px;  --rot:18deg;  --blur:26px; --col-inner:rgba(220,80,10,0.25); --col-mid:rgba(160,40,5,0.15);  --col-outer:rgba(60,15,0,0.06);"></div>
      <div class="smoke-wisp" style="--x:43%; --delay:2.5s; --dur:8s;  --size:170px; --drift:-55px; --rot:-20deg; --blur:18px; --col-inner:rgba(255,120,30,0.28); --col-mid:rgba(190,55,5,0.17);  --col-outer:rgba(70,20,0,0.07);"></div>
      <div class="smoke-wisp" style="--x:57%; --delay:0.7s; --dur:10s; --size:300px; --drift:25px;  --rot:10deg;  --blur:30px; --col-inner:rgba(200,60,5,0.22);  --col-mid:rgba(140,30,0,0.13);  --col-outer:rgba(50,10,0,0.05);"></div>
      <div class="smoke-wisp" style="--x:50%; --delay:3.8s; --dur:7.5s;--size:150px; --drift:-18px; --rot:-8deg;  --blur:16px; --col-inner:rgba(255,140,40,0.32); --col-mid:rgba(210,70,10,0.20); --col-outer:rgba(90,25,0,0.09);"></div>
      <div class="smoke-wisp" style="--x:46%; --delay:5s;   --dur:11s; --size:340px; --drift:65px;  --rot:25deg;  --blur:34px; --col-inner:rgba(180,50,5,0.20);  --col-mid:rgba(120,25,0,0.12);  --col-outer:rgba(45,10,0,0.05);"></div>
      <div class="smoke-wisp" style="--x:54%; --delay:4.2s; --dur:8.5s;--size:190px; --drift:-42px; --rot:-15deg; --blur:22px; --col-inner:rgba(255,90,15,0.26); --col-mid:rgba(195,45,5,0.16);  --col-outer:rgba(75,18,0,0.07);"></div>
      <div class="smoke-wisp" style="--x:51%; --delay:6.1s; --dur:9.5s;--size:140px; --drift:30px;  --rot:6deg;   --blur:15px; --col-inner:rgba(255,160,50,0.35); --col-mid:rgba(220,80,15,0.22); --col-outer:rgba(100,30,0,0.10);"></div>

      <!-- Fire embers -->
      <div class="ember" style="--x:48%;  --delay:0.3s;  --dur:3.2s; --size:3px; --col:#ff6a00; --glow:8px;  --drift:-22px; --rise:-340px;"></div>
      <div class="ember" style="--x:51%;  --delay:0.9s;  --dur:4.1s; --size:2px; --col:#ffaa00; --glow:6px;  --drift:18px;  --rise:-420px;"></div>
      <div class="ember" style="--x:49%;  --delay:1.5s;  --dur:3.6s; --size:4px; --col:#ff4400; --glow:10px; --drift:-40px; --rise:-300px;"></div>
      <div class="ember" style="--x:52%;  --delay:2.0s;  --dur:2.8s; --size:2px; --col:#ffcc00; --glow:7px;  --drift:30px;  --rise:-380px;"></div>
      <div class="ember" style="--x:47%;  --delay:2.7s;  --dur:4.5s; --size:3px; --col:#ff5500; --glow:9px;  --drift:-15px; --rise:-450px;"></div>
      <div class="ember" style="--x:53%;  --delay:0.5s;  --dur:3.9s; --size:2px; --col:#ff8800; --glow:6px;  --drift:42px;  --rise:-360px;"></div>
      <div class="ember" style="--x:50%;  --delay:3.3s;  --dur:3.1s; --size:4px; --col:#ff3300; --glow:11px; --drift:-28px; --rise:-310px;"></div>
      <div class="ember" style="--x:46%;  --delay:1.1s;  --dur:4.8s; --size:2px; --col:#ffdd00; --glow:7px;  --drift:55px;  --rise:-480px;"></div>
      <div class="ember" style="--x:54%;  --delay:4.0s;  --dur:3.4s; --size:3px; --col:#ff6600; --glow:8px;  --drift:-50px; --rise:-330px;"></div>
      <div class="ember" style="--x:51%;  --delay:5.2s;  --dur:2.6s; --size:2px; --col:#ff9900; --glow:6px;  --drift:12px;  --rise:-290px;"></div>
      <div class="ember" style="--x:49%;  --delay:6.0s;  --dur:4.2s; --size:3px; --col:#ff4400; --glow:9px;  --drift:-35px; --rise:-410px;"></div>
      <div class="ember" style="--x:52%;  --delay:1.8s;  --dur:3.7s; --size:2px; --col:#ffbb00; --glow:7px;  --drift:22px;  --rise:-350px;"></div>
      <div class="ember" style="--x:48%;  --delay:3.5s;  --dur:5.0s; --size:4px; --col:#ff2200; --glow:12px; --drift:-60px; --rise:-500px;"></div>
      <div class="ember" style="--x:53%;  --delay:0.2s;  --dur:3.3s; --size:2px; --col:#ffee00; --glow:6px;  --drift:38px;  --rise:-320px;"></div>
      <div class="ember" style="--x:50%;  --delay:7.0s;  --dur:4.0s; --size:3px; --col:#ff5000; --glow:8px;  --drift:-20px; --rise:-400px;"></div>
      <div class="ember" style="--x:44%;  --delay:2.2s;  --dur:3.5s; --size:2px; --col:#ff7700; --glow:7px;  --drift:48px;  --rise:-370px;"></div>
      <div class="ember" style="--x:56%;  --delay:4.8s;  --dur:2.9s; --size:3px; --col:#ff3300; --glow:9px;  --drift:-32px; --rise:-280px;"></div>
      <div class="ember" style="--x:51%;  --delay:5.6s;  --dur:4.4s; --size:2px; --col:#ffaa00; --glow:6px;  --drift:16px;  --rise:-440px;"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto">
      <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.75rem; letter-spacing:0.4em; text-transform:uppercase; margin-bottom:1.5rem; opacity:0; animation: fadeUp 0.8s ease 1.8s forwards;">
        ✦ &nbsp; A D&D Campaign Chronicle &nbsp; ✦
      </p>

      <!-- Logo -->
      <div class="logo-wrapper" style="margin-bottom:1.5rem; position:relative; display:inline-block;">
        <h1 class="logo-glitch" style="
          font-family: 'Cinzel Decorative', serif;
          font-size: clamp(2.5rem, 8vw, 6rem);
          font-weight: 700;
          color: #f0c040;
          line-height: 1.1;
          position: relative;
        ">
          The Motley<br/>Marauders
        </h1>
      </div>

      <div class="rune-divider" style="max-width:12rem; margin:0 auto 2rem; opacity:0; animation:fadeUp 0.8s ease 2s forwards;">
        <span style="color:#c9a227; font-size:1.8rem; line-height:1;">⚔</span>
      </div>

      <p style="
        color: #c9a96e;
        font-family: 'IM Fell English', serif;
        font-size: 1.2rem;
        font-style: italic;
        max-width: 36rem;
        margin: 0 auto 3rem;
        opacity: 0;
        animation: fadeUp 0.8s ease 2.2s forwards;
      ">
        Twelve unlikely souls. Countless terrible plans. One epic adventure — still in progress.
      </p>

      <!-- Rotating quote -->
      <div id="rotating-quote-wrap" class="parchment-card corner-ornament reveal-scale" style="max-width:48rem; margin:0 auto 3rem; padding:2rem; border-top:3px solid #c9a227; text-align:center;">
        <p style="font-family:'Cinzel',serif; color:#6b5a3e; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:1.5rem;">✦ Quote of the Campaign ✦</p>
        <blockquote id="rq-blockquote">
          <p id="rq-text" style="font-family:'IM Fell English',serif; font-style:italic; color:#e8d5b0; font-size:1.4rem; line-height:1.6; margin-bottom:1rem;"></p>
          <footer id="rq-speaker" style="font-family:'Cinzel',serif; font-size:0.875rem; color:#c9a227; font-style:normal;"></footer>
        </blockquote>
        <p id="rq-context" style="font-size:0.9rem; margin-top:1rem; font-style:italic; color:#a08860; font-weight:500; line-height:1.5;"></p>
      </div>

      <script define:vars={{ rqQuotes: quotes.map(q => ({ text: q.text, speaker: q.speaker, context: q.context || '' })) }}>
      (function () {
        const wrap    = document.getElementById('rotating-quote-wrap');
        const text    = document.getElementById('rq-text');
        const speaker = document.getElementById('rq-speaker');
        const context = document.getElementById('rq-context');
        const FADE    = 1400;
        const HOLD    = 5500;
        let idx = 0;

        function setQuote(q) {
          text.textContent    = '\u201C' + q.text + '\u201D';
          speaker.textContent = '\u2014 ' + q.speaker;
          context.textContent = q.context;
        }

        function cycle() {
          wrap.style.opacity = '0';
          setTimeout(() => {
            idx = (idx + 1) % rqQuotes.length;
            setQuote(rqQuotes[idx]);
            wrap.style.opacity = '1';
          }, FADE);
        }

        setQuote(rqQuotes[0]);
        // Add transition after hero animation completes so they don't conflict
        setTimeout(() => { wrap.style.transition = 'opacity 1.4s ease'; }, 800);
        setInterval(cycle, HOLD + FADE);
      })();
      </script>

      <!-- CTAs -->
      <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center; opacity:0; animation:fadeUp 0.8s ease 2.8s forwards;">
        <a href="/story" class="hero-btn hero-btn-primary">Read the Chronicle</a>
        <a href="/characters" class="hero-btn hero-btn-secondary">Meet the Party</a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div style="position:absolute; bottom:2rem; left:50%; transform:translateX(-50%); opacity:0.4;" class="animate-bounce">
      <svg width="24" height="24" fill="none" stroke="#c9a227" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- Latest session -->
  <section class="reveal" style="padding:5rem 1rem;">
    <div style="max-width:72rem; margin:0 auto;">
      <div style="text-align:center; margin-bottom:3rem;">
        <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.75rem; letter-spacing:0.3em; text-transform:uppercase; margin-bottom:0.75rem;">Latest Chapter</p>
        <h2 style="font-family:'Cinzel',serif; color:#e8d5b0; font-size:1.875rem; font-weight:700;">Session {latestSession.session}</h2>
      </div>

      <div class="parchment-card corner-ornament" style="padding:2rem; max-width:48rem; margin:0 auto;">
        <div style="margin-bottom:1rem;">
          <h3 style="font-family:'Cinzel',serif; color:#f0c040; font-size:1.25rem; font-weight:700; margin-bottom:0.25rem;">{latestSession.title}</h3>
          <p style="color:#c9a227; font-family:'Cinzel',serif; font-size:0.875rem;">{latestSession.location}</p>
        </div>

        <p style="color:#c9a96e; line-height:1.75; margin-bottom:1.5rem;">{latestSession.summary}</p>

        {latestSession.cliffhanger && (
          <div style="border-left:2px solid #c0392b; padding-left:1rem; font-style:italic; color:#f0a090; font-weight:500;">
            <span style="font-family:'Cinzel',serif; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.08em; color:#c0392b; font-style:normal; display:block; margin-bottom:0.25rem; font-weight:600;">⚠ Cliffhanger</span>
            "{latestSession.cliffhanger}"
          </div>
        )}

        <div style="margin-top:1.5rem; text-align:right;">
          <a href="/story" class="card-link" style="font-size:0.75rem; letter-spacing:0.12em; text-transform:uppercase;">All Sessions →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Party snapshot carousel -->
  <section class="reveal" style="padding:5rem 0; background:linear-gradient(to bottom, transparent, rgba(26,18,8,0.4), transparent);">
    <div style="text-align:center; margin-bottom:3rem; padding:0 1rem;">
      <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.75rem; letter-spacing:0.3em; text-transform:uppercase; margin-bottom:0.75rem;">The Adventuring Party</p>
      <h2 style="font-family:'Cinzel',serif; color:#e8d5b0; font-size:1.875rem; font-weight:700;">The Marauders</h2>
    </div>

    <div class="carousel-outer">
      <!-- Prev arrow -->
      <button class="carousel-arrow carousel-arrow-prev" id="carousel-prev" aria-label="Previous">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>

      <!-- Scrollable viewport -->
      <div class="carousel-mask">
        <div class="carousel-viewport" id="carousel-viewport">
          <div class="carousel-track">
            {characters.map(char => (
              <a
                href={`/characters#${char.name.toLowerCase().replace(/[\s()\/]/g,'-').replace(/-+/g,'-')}`}
                class="carousel-card parchment-card"
              >
                {char.image ? (
                  <div style="height:260px; overflow:hidden; position:relative;">
                    <img
                      src={char.image}
                      alt={char.name}
                      style="width:100%; height:100%; object-fit:cover; object-position:top; filter:sepia(15%) contrast(1.05);"
                    />
                    <div style="position:absolute; inset:0; background:linear-gradient(to top, #1a1208 0%, transparent 55%);"></div>
                  </div>
                ) : (
                  <div style="height:260px; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,#1a1208,#231a0e); font-size:3.5rem;">
                    {char.icon}
                  </div>
                )}
                <div style="padding:1rem; text-align:center;">
                  <h3 style="font-family:'Cinzel',serif; color:#e8d5b0; font-size:0.85rem; font-weight:700; margin-bottom:0.4rem; line-height:1.2;">
                    {char.name.split(' ')[0].split('(')[0].trim()}
                  </h3>
                  <span class={`badge-${char.classSlug}`} style="font-family:'Cinzel',serif; font-size:0.62rem; padding:0.15rem 0.5rem; border:1px solid; border-radius:9999px; display:inline-block;">
                    {char.class.split('/')[0].trim()}
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Next arrow -->
      <button class="carousel-arrow carousel-arrow-next" id="carousel-next" aria-label="Next">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>

    <div style="text-align:center; margin-top:2.5rem; padding:0 1rem;">
      <a href="/characters" class="site-btn">View Full Bios</a>
    </div>
  </section>

  <!-- Realm Map -->
  <section class="reveal-scale" style="padding:5rem 1rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:2rem;">
        <p style="font-family:'Cinzel',serif;color:#c9a227;font-size:0.75rem;letter-spacing:0.3em;text-transform:uppercase;margin-bottom:0.5rem;">The Known World</p>
        <h2 style="font-family:'Cinzel Decorative',serif;color:#f0c040;font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;" class="text-glow-gold">The Realm Map</h2>
      </div>
      <img src="/map.png" alt="Map of the Realm" style="width:100%;max-width:700px;display:block;margin:0 auto;"/>
      <div style="text-align:center;margin-top:1.5rem;">
        <a href="/journey" class="site-btn">Explore the Journey</a>
      </div>
    </div>
  </section>

  <!-- Quote reel -->
  <section class="reveal" style="padding:5rem 1rem;">
    <div style="max-width:56rem; margin:0 auto;">
      <div style="text-align:center; margin-bottom:3rem;">
        <p style="font-family:'Cinzel',serif; color:#c9a227; font-size:0.75rem; letter-spacing:0.3em; text-transform:uppercase; margin-bottom:0.75rem;">Words of Wisdom (Debatable)</p>
        <h2 style="font-family:'Cinzel',serif; color:#e8d5b0; font-size:1.875rem; font-weight:700;">From the Mouths of Marauders</h2>
      </div>

      <div style="display:grid; gap:1.5rem; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));">
        {quotes.slice(0, 4).map(quote => (
          <div class="parchment-card" style="padding:1.5rem;">
            <blockquote class="dnd-quote" style="margin-bottom:0.75rem;">
              <p>"{quote.text}"</p>
            </blockquote>
            <p style="font-family:'Cinzel',serif; font-size:0.75rem; color:#c9a227;">— {quote.speaker}</p>
            <p style="font-size:0.875rem; margin-top:0.25rem; font-style:italic; color:#a08860; font-weight:500;">{quote.context}</p>
          </div>
        ))}
      </div>

      <div style="text-align:center; margin-top:2rem;">
        <a href="/quotes" class="site-btn">All Quotes</a>
      </div>
    </div>
  </section>

<script is:inline>
(function () {
  const viewport = document.getElementById('carousel-viewport');
  const prev     = document.getElementById('carousel-prev');
  const next     = document.getElementById('carousel-next');
  if (!viewport || !prev || !next) return;

  const track = viewport.querySelector('.carousel-track');
  if (!track) return;

  // ── Clone setup ──────────────────────────────────────────
  const originals = Array.from(track.querySelectorAll('.carousel-card'));
  const n = originals.length;

  const makeSet = () => {
    const frag = document.createDocumentFragment();
    originals.forEach(card => {
      const c = card.cloneNode(true);
      c.setAttribute('aria-hidden', 'true');
      frag.appendChild(c);
    });
    return frag;
  };

  // Build: [before][originals][after]
  track.appendChild(makeSet());
  track.insertBefore(makeSet(), track.firstChild);

  // ── Measurement ──────────────────────────────────────────
  const CARD_W  = () => (track.children[0]?.offsetWidth ?? 230) + 16;
  const setW    = () => n * CARD_W();

  // ── State ─────────────────────────────────────────────────
  // offset = how far left the track has been translated (px)
  // starts at setW so we're looking at the originals
  let offset = setW();

  const setTransform = (px, animated) => {
    track.style.transition = animated
      ? 'transform 0.42s cubic-bezier(0.25, 0.46, 0.45, 0.94)'
      : 'none';
    track.style.transform = `translateX(${-px}px)`;
    offset = px;
  };

  setTransform(offset, false);

  // After each animated step, silently normalise back into the originals zone
  const normalise = () => {
    const s = setW();
    let o = offset;
    // wrap into [s, 2s)
    while (o >= 2 * s) o -= s;
    while (o < s)      o += s;
    if (o !== offset) setTransform(o, false);
  };

  // ── Arrow buttons ─────────────────────────────────────────
  let busy = false;

  const step = (dir) => {
    if (busy) return;
    busy = true;
    setTransform(offset + dir * CARD_W(), true);

    // Wait for transition then normalise + unlock
    track.addEventListener('transitionend', function onEnd() {
      track.removeEventListener('transitionend', onEnd);
      normalise();
      busy = false;
    }, { once: true });
  };

  prev.addEventListener('click', () => step(-1));
  next.addEventListener('click', () => step(1));
  prev.disabled = false;
  next.disabled = false;

  // ── Keyboard ──────────────────────────────────────────────
  viewport.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft')  { e.preventDefault(); step(-1); }
    if (e.key === 'ArrowRight') { e.preventDefault(); step(1); }
  });

  // ── Drag (mouse + touch) ──────────────────────────────────
  let dragStartX   = null;
  let dragStartOff = 0;
  let dragged      = false;

  const onDragStart = (clientX) => {
    if (busy) return;
    dragStartX   = clientX;
    dragStartOff = offset;
    dragged      = false;
    track.style.transition = 'none';
    viewport.classList.add('grabbing');
  };

  const onDragMove = (clientX) => {
    if (dragStartX === null) return;
    const delta = dragStartX - clientX;
    if (Math.abs(delta) > 4) dragged = true;
    track.style.transform = `translateX(${-(dragStartOff + delta)}px)`;
    offset = dragStartOff + delta;
  };

  const onDragEnd = () => {
    if (dragStartX === null) return;
    dragStartX = null;
    viewport.classList.remove('grabbing');

    // Snap to nearest card
    const cw = CARD_W();
    const snapped = Math.round(offset / cw) * cw;
    setTransform(snapped, true);
    track.addEventListener('transitionend', function onEnd() {
      track.removeEventListener('transitionend', onEnd);
      normalise();
    }, { once: true });
  };

  viewport.addEventListener('mousedown',  (e) => onDragStart(e.clientX));
  window .addEventListener('mousemove',   (e) => onDragMove(e.clientX));
  window .addEventListener('mouseup',     ()  => onDragEnd());
  viewport.addEventListener('touchstart', (e) => onDragStart(e.touches[0].clientX), { passive: true });
  viewport.addEventListener('touchmove',  (e) => onDragMove(e.touches[0].clientX),  { passive: true });
  viewport.addEventListener('touchend',   ()  => onDragEnd());

  // Prevent card link navigation while dragging
  viewport.addEventListener('click', (e) => {
    if (dragged) e.preventDefault();
  });

  // ── Wheel → step ──────────────────────────────────────────
  let wheelTimer;
  viewport.addEventListener('wheel', (e) => {
    e.preventDefault();
    clearTimeout(wheelTimer);
    wheelTimer = setTimeout(() => {
      step(e.deltaX > 0 || e.deltaY > 0 ? 1 : -1);
    }, 50);
  }, { passive: false });
})();
</script>
</Layout>

